S.Players.PlayerAdded:Connect(setupPlayer)
S.Players.PlayerRemoving:Connect(function(player)
    destroyTag(player)
end)

task.wait(0)
for _, p in S.Players:GetPlayers() do
    setupPlayer(p)
end
