local function cleanupPlayer(player)
    local data = tagData[player]
    if not data then return end

    if data.charConns then
        for _, conn in data.charConns do
            conn:Disconnect()
        end
        data.charConns = nil
    end

    destroyTagUI(player, false)

    widthCache[player.UserId] = nil
    tagData[player] = nil
end

local function setupPlayer(player)
    if player == lp then return end
    if tagData[player] then return end

    tagData[player] = {
        refs         = nil,
        charConns    = nil,
        fadeState    = "idle",
        fadeAlpha    = 1,
        building     = false,
        distTimer    = 0,
        currentTrans = 1,
    }

    local data = tagData[player]

    -- FIX: sprawdzenie `enabled` wewnątrz CharacterAdded — bez tego nowi gracze
    -- mogą dostawać zombie-tagi gdy system jest wyłączony
    local charAdded = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head = newChar:WaitForChild("Head", 5)
            if not head or not tagData[player] then return end
            if not enabled then return end  -- ← KLUCZOWY FIX
            attachToHead(player, head, false)
        end)
    end)

    -- CharacterRemoving — fade-out przy despawnie
    -- FIX: nie resetujemy fadeAlpha do 0 — zaczynamy od aktualnej wartości
    local charRemoving = player.CharacterRemoving:Connect(function()
        local d = tagData[player]
        if d and d.refs then
            d.fadeState = "out"
            -- fadeAlpha zostaje na aktualnej wartości — bez flasha
        end
    end)

    data.charConns = { charAdded, charRemoving }

    -- Jeśli postać już istnieje w momencie setupu i system jest włączony
    if enabled then
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            attachToHead(player, head, false)
        end
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API
-- ─────────────────────────────────────────────

getgenv().Nametags = {

    enable = function()
        if enabled and not isTransitioning then return end

        isTransitioning = true
        enabled = true

        if masterAlphaConn then
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
        end
        -- Reset do 1 — wszystkie tagi startują jako ukryte, razem fade-in przez masterAlpha
        masterAlpha = 1

        -- Globalna pętla HB musi działać zanim zaczniemy budować tagi
        startGlobalHeartbeat()

        -- Zbuduj UI dla wszystkich obecnych graczy
        -- toggleBuild = true → fadeState idle, masterAlpha steruje wszystkimi synchronicznie
        for _, player in Players:GetPlayers() do
            if player == lp then continue end

            if not tagData[player] then
                setupPlayer(player)
            end

            local data = tagData[player]
            if not data then continue end
            if data.fadeState == "out" then continue end

            -- Reset stanu przed budową
            data.fadeState    = "idle"
            data.fadeAlpha    = 0
            data.currentTrans = 1

            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if head and not data.building then
                attachToHead(player, head, true)
            elseif data.refs then
                -- Tag już istnieje — ukryj przed animacją
                data.refs.canvas.GroupTransparency       = 1
                data.refs.shadowCanvas.GroupTransparency = 1
                data.currentTrans = 1
            end
        end

        -- Wszyscy gotowi i ukryci — odpal synchroniczny fade-in
        animateMasterAlpha(0, CFG.ToggleLerpSpeed, function()
            isTransitioning = false
        end)
    end,

    disable = function()
        if not enabled and not isTransitioning then return end

        enabled = false
        isTransitioning = true

        -- Zatrzymaj wszystkie per-player fade-in żeby masterAlpha był jedynym sterownikiem
        for _, data in tagData do
            if data.fadeState == "in" then
                data.fadeState = "idle"
                data.fadeAlpha = 0
            end
        end

        animateMasterAlpha(1, CFG.ToggleLerpSpeed, function()
            isTransitioning = false

            -- FIX: Najpierw zatrzymaj HB — potem niszcz UI
            -- Dzięki temu HB nie może tworzyć zombie podczas czyszczenia
            if globalHeartbeat then
                globalHeartbeat:Disconnect()
                globalHeartbeat = nil
            end

            -- Zniszcz wszystkie UI natychmiast (masterAlpha = 1, już ukryte)
            for player, _ in tagData do
                destroyTagUI(player, false)
            end

            widthCache = {}
        end)
    end,

    -- FIX: poprawna funkcja gradientu — kolor zależy od przekazanego koloru
    setColor = function(color)
        accentColor = color
        local newGradient = accentGradientColor(color)
        for _, data in tagData do
            if data.refs then
                local refs = data.refs
                refs.accentBar.BackgroundColor3 = color
                refs.accentGrad.Color           = newGradient
                refs.ring.BackgroundColor3      = color
            end
        end
    end,
}

-- Shortcuty dla script huba
getgenv().enableNametags     = getgenv().Nametags.enable
getgenv().disableNametags    = getgenv().Nametags.disable
getgenv().updateNametagColor = getgenv().Nametags.setColor

