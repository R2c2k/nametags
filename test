-- ─────────────────────────────────────────────
--   Utility
-- ─────────────────────────────────────────────

local function lerp(a, b, t)
    return a + (b - a) * t
end

-- Interpolacja kolorów bez alokacji przez lerpColor w pętli —
-- używamy bezpośrednio Color3.new zamiast pośredniej funkcji
local function lerpColor(c1, c2, t)
    return Color3.new(
        c1.R + (c2.R - c1.R) * t,
        c1.G + (c2.G - c1.G) * t,
        c1.B + (c2.B - c1.B) * t
    )
end

-- Kolor w zależności od dystansu (zielony → żółty → czerwony)
local function distColor(d)
    local mid = (CFG.DistClose + CFG.DistFar) * 0.5
    if d <= CFG.DistClose then
        return CFG.ColorClose
    elseif d <= mid then
        return lerpColor(CFG.ColorClose, CFG.ColorMid, (d - CFG.DistClose) / (mid - CFG.DistClose))
    elseif d <= CFG.DistFar then
        return lerpColor(CFG.ColorMid, CFG.ColorFar, (d - mid) / (CFG.DistFar - mid))
    else
        return CFG.ColorFar
    end
end

-- Przezroczystość w zależności od dystansu
-- 0 = w pełni widoczny, 1 = niewidoczny
local function fadeTrans(d)
    if d < CFG.FadeNearMin then return 1 end
    if d < CFG.FadeNearMax then return 1 - (d - CFG.FadeNearMin) / (CFG.FadeNearMax - CFG.FadeNearMin) end
    if d < CFG.FadeFarMin  then return 0 end
    if d < CFG.FadeFarMax  then return (d - CFG.FadeFarMin) / (CFG.FadeFarMax - CFG.FadeFarMin) end
    return 1
end

-- Szerokość tagu z cache — GetTextSize wywoływane tylko raz na gracza
local function calcWidth(dispName, userName)
    local key = dispName .. "|" .. userName
    if widthCache[key] then return widthCache[key] end

    local avatarOffset = CFG.AvatarSize + 18
    local bigBounds    = Vector2.new(9999, 16)
    local subBounds    = Vector2.new(9999, 13)

    local w = math.max(
        TextService:GetTextSize(dispName,         11, CFG.FontMain, bigBounds).X,
        TextService:GetTextSize("@" .. userName,   9, CFG.FontSub,  subBounds).X,
        TextService:GetTextSize("999 studs",        8, CFG.FontMeta, subBounds).X
    )

    local result = math.clamp(avatarOffset + w + CFG.WidthPadR, CFG.WidthMin, CFG.WidthMax)
    widthCache[key] = result
    return result
end

-- Projekcja world → screen (nil jeśli za kamerą)
local function worldToScreen(pos)
    local sp, onScreen = Camera:WorldToScreenPoint(pos)
    if not onScreen or sp.Z <= 0 then return nil end
    return Vector2.new(sp.X, sp.Y)
end

-- Przyciemniony akcent dla gradientu paska
local function accentDark(color)
    return Color3.new(color.R * 0.6, color.G * 0.6, color.B * 0.6)
end

-- Pomocnik: tworzy TextLabel z podanymi właściwościami
local function makeLabel(parent, props)
    local label = Instance.new("TextLabel", parent)
    for k, v in props do label[k] = v end
    return label
end

-- Pomocnik: tworzy Frame z podanymi właściwościami
local function makeFrame(parent, props)
    local frame = Instance.new("Frame", parent)
    for k, v in props do frame[k] = v end
    return frame
end

-- ─────────────────────────────────────────────
--   Budowanie UI
--   BillboardGui siedzi w CoreGui (fix Head.Locked),
--   Head wskazany przez Adornee.
-- ─────────────────────────────────────────────

local function buildUI(player, head)
    local totalWidth  = calcWidth(player.DisplayName, player.Name)
    local textOffset  = CFG.AvatarSize + 18
    local textWidth   = totalWidth - textOffset - CFG.WidthPadR
    local refs        = {}

    -- BillboardGui
    refs.billboard = Instance.new("BillboardGui")
    refs.billboard.Name             = "DarkNametag_" .. player.Name
    refs.billboard.Adornee          = head
    refs.billboard.Size             = UDim2.fromOffset(totalWidth, CFG.Height)
    refs.billboard.StudsOffset      = CFG.StudsOffset
    refs.billboard.AlwaysOnTop      = CFG.AlwaysOnTop
    refs.billboard.ResetOnSpawn     = false
    refs.billboard.ClipsDescendants = false
    refs.billboard.Parent           = tagContainer

    -- CanvasGroup: płynne fade przez GroupTransparency
    -- Zaczyna od 1 (niewidoczny) → ease-in przy pojawieniu się
    refs.canvas = Instance.new("CanvasGroup", refs.billboard)
    refs.canvas.Size                   = UDim2.fromScale(1, 1)
    refs.canvas.BackgroundTransparency = 1
    refs.canvas.GroupTransparency      = 1  -- ease-in: zaczyna niewidoczny

    -- Cień
    local shadow = makeFrame(refs.canvas, {
        Size                   = UDim2.fromScale(1, 1),
        Position               = UDim2.fromOffset(2, 3),
        BackgroundColor3       = CFG.ShadowColor,
        BackgroundTransparency = CFG.ShadowTrans,
        BorderSizePixel        = 0,
        ZIndex                 = 1,
    })
    Instance.new("UICorner", shadow).CornerRadius = UDim.new(0, 8)

    -- Tło szklane
    local glass = makeFrame(refs.canvas, {
        Size                   = UDim2.fromScale(1, 1),
        BackgroundColor3       = CFG.GlassColor,
        BackgroundTransparency = CFG.GlassTrans,
        BorderSizePixel        = 0,
        ZIndex                 = 2,
    })
    Instance.new("UICorner", glass).CornerRadius = UDim.new(0, 8)

    -- Obramowanie
    local stroke = Instance.new("UIStroke", glass)
    stroke.Color           = CFG.BorderColor
    stroke.Transparency    = CFG.BorderTrans
    stroke.Thickness       = 1
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    -- Pasek akcentowy (pionowy, z lewej)
    refs.accentBar = makeFrame(glass, {
        Name             = "AccentBar",
        Size             = UDim2.new(0, 3, 1, -12),
        Position         = UDim2.fromOffset(5, 6),
        BackgroundColor3 = accentColor,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    })
    Instance.new("UICorner", refs.accentBar).CornerRadius = UDim.new(0, 3)

    refs.accentGrad = Instance.new("UIGradient", refs.accentBar)
    refs.accentGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
        ColorSequenceKeypoint.new(1, accentDark(accentColor)),
    })
    refs.accentGrad.Rotation = 90

    -- Ring wokół avatara
    refs.ring = makeFrame(glass, {
        Size             = UDim2.fromOffset(CFG.AvatarSize + 3, CFG.AvatarSize + 3),
        Position         = UDim2.new(0, 12, 0.5, 0),
        AnchorPoint      = Vector2.new(0, 0.5),
        BackgroundColor3 = accentColor,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    })
    Instance.new("UICorner", refs.ring).CornerRadius = UDim.new(1, 0)

    -- Avatar
    local avatarLabel = Instance.new("ImageLabel", glass)
    avatarLabel.Name                   = "Avatar"
    avatarLabel.Size                   = UDim2.fromOffset(CFG.AvatarSize, CFG.AvatarSize)
    avatarLabel.Position               = UDim2.new(0, 13, 0.5, 0)
    avatarLabel.AnchorPoint            = Vector2.new(0, 0.5)
    avatarLabel.BackgroundColor3       = Color3.fromRGB(30, 30, 38)
    avatarLabel.BackgroundTransparency = 0
    avatarLabel.Image                  = ""
    avatarLabel.ZIndex                 = 4
    Instance.new("UICorner", avatarLabel).CornerRadius = UDim.new(1, 0)

    -- Pobieranie avatara z cache lub z sieci
    -- Cache po UserId — przy respawnie nie pobiera ponownie
    local userId = player.UserId
    if avatarCache[userId] then
        avatarLabel.Image                  = avatarCache[userId]
        avatarLabel.BackgroundTransparency = 1
    else
        task.spawn(function()
            local ok, img = pcall(
                Players.GetUserThumbnailAsync, Players,
                userId,
                Enum.ThumbnailType.HeadShot,
                Enum.ThumbnailSize.Size48x48
            )
            -- Sprawdzamy czy label wciąż istnieje zanim ustawimy obraz
            if ok and img and avatarLabel.Parent then
                avatarCache[userId]                = img
                avatarLabel.Image                  = img
                avatarLabel.BackgroundTransparency = 1
            end
        end)
    end

    -- Nazwa wyświetlana
    makeLabel(glass, {
        Text                   = player.DisplayName,
        Size                   = UDim2.fromOffset(textWidth, 16),
        Position               = UDim2.fromOffset(textOffset, 6),
        Font                   = CFG.FontMain,
        TextColor3             = CFG.TextMain,
        TextSize               = 11,
        TextScaled             = false,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 4,
    })

    -- Username
    makeLabel(glass, {
        Text                   = "@" .. player.Name,
        Size                   = UDim2.fromOffset(textWidth, 12),
        Position               = UDim2.fromOffset(textOffset, 21),
        Font                   = CFG.FontSub,
        TextColor3             = CFG.TextSub,
        TextSize               = 9,
        TextScaled             = false,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 4,
    })

    -- Separator poziomy
    local sep = makeFrame(glass, {
        Size                   = UDim2.new(0, textWidth, 0, 1),
        Position               = UDim2.fromOffset(textOffset, 32),
        BackgroundColor3       = CFG.SepColor,
        BackgroundTransparency = 0,
        BorderSizePixel        = 0,
        ZIndex                 = 4,
    })
    Instance.new("UIGradient", sep).Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0,   0),
        NumberSequenceKeypoint.new(0.7, 0),
        NumberSequenceKeypoint.new(1,   1),
    })

    -- Dot kolorowy (wskaźnik dystansu)
    refs.distDot = makeLabel(glass, {
        Text                   = "●",
        Size                   = UDim2.fromOffset(10, 11),
        Position               = UDim2.fromOffset(textOffset, 34),
        Font                   = CFG.FontMeta,
        TextColor3             = CFG.ColorClose,
        TextSize               = 7,
        TextScaled             = false,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 4,
    })

    -- Etykieta dystansu
    -- Zaczyna pusta — wypełniana dopiero po pierwszym pomiarze,
    -- żeby nie pokazywać "0 studs" przez pierwszą klatkę
    refs.distLabel = makeLabel(glass, {
        Name                   = "Distance",
        Text                   = "",
        Size                   = UDim2.fromOffset(textWidth - 12, 11),
        Position               = UDim2.fromOffset(textOffset + 11, 34),
        Font                   = CFG.FontMeta,
        TextColor3             = CFG.TextMeta,
        TextSize               = 8,
        TextScaled             = false,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 4,
    })

    return refs
end

-- ─────────────────────────────────────────────
--   Pętla per-gracz (Heartbeat)
--   Obsługuje fade i aktualizację dystansu
-- ─────────────────────────────────────────────

local function startPlayerLoop(player, refs)
    -- currentTrans zaczyna od 1 (niewidoczny) → ease-in
    local currentTrans = 1
    local distTimer    = 0
    local conn

    conn = RunService.Heartbeat:Connect(function(dt)
        -- Jeśli billboard zniknął — zakończ pętlę
        if not refs.billboard or not refs.billboard.Parent then
            conn:Disconnect()
            return
        end

        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        local char   = player.Character
        local head   = char and char:FindFirstChild("Head")

        -- Brak postaci gracza lub naszej: ukryj płynnie
        if not lpRoot or not head then
            currentTrans = lerp(currentTrans, 1, math.min(dt * CFG.LerpSpeed, 1))
            refs.canvas.GroupTransparency = currentTrans
            return
        end

        -- Dystans liczony raz na klatkę
        local dist = (head.Position - lpRoot.Position).Magnitude

        -- Aktualizacja tekstu dystansu z throttlem
        -- Tekst pojawia się dopiero po pierwszym pomiarze (nie "0 studs")
        distTimer = distTimer + dt
        if distTimer >= CFG.DistThrottle then
            distTimer = 0
            local dc = distColor(dist)
            refs.distLabel.Text      = string.format("%.0f studs", dist)
            refs.distDot.TextColor3  = dc
            refs.distLabel.TextColor3 = dc
        end

        -- Przezroczystość: max z fade dystansowego i overlap penalty
        local data       = tagData[player]
        local overlapPen = data and data.overlapTrans or 0
        local targetTrans = math.max(fadeTrans(dist), overlapPen)

        currentTrans = lerp(currentTrans, targetTrans, math.min(dt * CFG.LerpSpeed, 1))
        refs.canvas.GroupTransparency = currentTrans
    end)

    return conn
end

-- ─────────────────────────────────────────────
--   Globalny overlap loop (throttlowany)
-- ─────────────────────────────────────────────

local function startGlobalLoop()
    if globalLoop then
        globalLoop:Disconnect()
        globalLoop = nil
    end

    local overlapTimer = 0

    globalLoop = RunService.Heartbeat:Connect(function(dt)
        overlapTimer = overlapTimer + dt
        if overlapTimer < CFG.OverlapThrottle then return end
        overlapTimer = 0

        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")

        -- Zbierz widocznych graczy z pozycją na ekranie
        local entries = {}
        for pl, data in tagData do
            if not data.refs then continue end
            local char = pl.Character
            local head = char and char:FindFirstChild("Head")
            if not head then continue end

            local dist = lpRoot
                and (head.Position - lpRoot.Position).Magnitude
                or math.huge

            table.insert(entries, {
                player   = pl,
                dist     = dist,
                screenPos = worldToScreen(head.Position + CFG.StudsOffset),
            })
        end

        -- Sortuj od najbliższego: bliższy gracz nie jest ukrywany przez dalszego
        table.sort(entries, function(a, b) return a.dist < b.dist end)

        -- Resetuj overlap dla wszystkich
        for _, entry in entries do
            local data = tagData[entry.player]
            if data then data.overlapTrans = 0 end
        end

        -- Wykryj nakładające się tagi (O(n²), akceptowalne dla <50 graczy)
        for i = 1, #entries do
            if not entries[i].screenPos then continue end
            for j = i + 1, #entries do
                if not entries[j].screenPos then continue end

                local px = (entries[i].screenPos - entries[j].screenPos).Magnitude
                if px < CFG.OverlapPx then
                    local data = tagData[entries[j].player]
                    if data then
                        data.overlapTrans = math.max(
                            data.overlapTrans or 0,
                            (1 - px / CFG.OverlapPx) * CFG.OverlapBonus
                        )
                    end
                end
            end
        end
    end)
end

-- ─────────────────────────────────────────────
--   Lifecycle taga
-- ─────────────────────────────────────────────

-- Niszczy tylko UI (billboard + heartbeat), zachowuje wpis w tagData
local function destroyTagUI(player)
    local data = tagData[player]
    if not data then return end

    if data.heartbeat then
        data.heartbeat:Disconnect()
        data.heartbeat = nil
    end

    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        data.refs.billboard:Destroy()
    end

    data.refs         = nil
    data.overlapTrans = 0
end

-- Niszczy wszystko włącznie z wpisem w tagData
local function destroyTag(player)
    local data = tagData[player]
    if not data then return end

    destroyTagUI(player)

    if data.charConn then
        data.charConn:Disconnect()
        data.charConn = nil
    end

    data.watchToken = nil
    tagData[player] = nil
end

-- ─────────────────────────────────────────────
--   Podpięcie taga pod głowę gracza
-- ─────────────────────────────────────────────

local function attachToHead(player, head)
    local data = tagData[player]
    if not data or not enabled then return end
    if not head or not head.Parent then return end

    -- Jeśli billboard już istnieje — tylko zaktualizuj Adornee
    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        if data.refs.billboard.Adornee ~= head then
            data.refs.billboard.Adornee = head
        end
        return
    end

    -- Buduj UI od nowa
    destroyTagUI(player)

    local ok, err = pcall(function()
        local refs      = buildUI(player, head)
        local heartbeat = startPlayerLoop(player, refs)
        data.refs       = refs
        data.heartbeat  = heartbeat
    end)

    if not ok then
        warn("[Nametags] attachToHead [" .. player.Name .. "]: " .. tostring(err))
    end
end

-- ─────────────────────────────────────────────
--   Watcher — polling co WatcherInterval
--   Wykrywa: respawn, ;char, brak postaci
--   Startuje sprawdzenie NATYCHMIAST, potem czeka
-- ─────────────────────────────────────────────

local function startWatcher(player)
    local data = tagData[player]
    if not data then return end

    -- Token unieważnia poprzedni watcher przy ponownym starcie
    local token = {}
    data.watchToken = token

    task.spawn(function()
        while true do
            -- Sprawdź najpierw, potem czekaj — brak opóźnienia przy enable
            local current = tagData[player]
            if not current or current.watchToken ~= token or not enabled then
                return
            end

            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if not char or not head then
                -- Postać zniknęła (;char, śmierć, etc.) — zniszcz UI
                if current.refs then
                    destroyTagUI(player)
                end
            elseif not current.refs or not current.refs.billboard or not current.refs.billboard.Parent then
                -- Postać istnieje ale brak UI — zbuduj
                attachToHead(player, head)
            elseif current.refs.billboard.Adornee ~= head then
                -- Head się zmienił (nowa postać, ;char) — zaktualizuj Adornee
                current.refs.billboard.Adornee = head
            end

            task.wait(CFG.WatcherInterval)
        end
    end)
end

-- ─────────────────────────────────────────────
--   Inicjalizacja gracza
-- ─────────────────────────────────────────────

local function setupPlayer(player)
    -- Pomijamy siebie
    if player == lp then return end
    -- Jeśli już zainicjalizowany — pomijamy (idempotent)
    if tagData[player] then return end

    tagData[player] = {
        refs         = nil,
        heartbeat    = nil,
        charConn     = nil,
        watchToken   = nil,
        overlapTrans = 0,
    }

    local data = tagData[player]

    -- CharacterAdded: szybka ścieżka dla respawnu i ;char
    data.charConn = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            -- WaitForChild z timeoutem zamiast własnej pętli polling
            local head = newChar:WaitForChild("Head", 5)
            if not head or not tagData[player] then return end
            attachToHead(player, head)
        end)
    end)

    -- Watcher startuje tylko gdy nametagi są włączone
    if enabled then
        startWatcher(player)
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API (przez getgenv dla Rayfield)
-- ─────────────────────────────────────────────

getgenv().enableNametags = function()
    enabled = true

    for _, player in Players:GetPlayers() do
        if player == lp then continue end

        if not tagData[player] then
            -- Nowy gracz — pełna inicjalizacja
            setupPlayer(player)
            startWatcher(player)
        else
            local data = tagData[player]
            -- Watcher może być martwy — wznów go
            if not data.watchToken then
                startWatcher(player)
            end
        end
    end

    startGlobalLoop()
end

getgenv().disableNametags = function()
    enabled = false

    for player, data in tagData do
        destroyTagUI(player)
        data.watchToken = nil  -- zatrzymuje watcher
    end

    if globalLoop then
        globalLoop:Disconnect()
        globalLoop = nil
    end
end

-- Aktualizuje kolor akcentu na wszystkich aktywnych tagach
getgenv().updateNametagColor = function(color)
    accentColor = color

    for _, data in tagData do
        if data.refs then
            data.refs.accentBar.BackgroundColor3 = color
            data.refs.accentGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                ColorSequenceKeypoint.new(1, accentDark(color)),
            })
            data.refs.ring.BackgroundColor3 = color
        end
    end
end

-- ─────────────────────────────────────────────
--   Zdarzenia i inicjalizacja przy ładowaniu
-- ─────────────────────────────────────────────

Players.PlayerAdded:Connect(setupPlayer)
Players.PlayerRemoving:Connect(destroyTag)

-- Inicjalizacja graczy już w grze
task.wait(0)
for _, player in Players:GetPlayers() do
    setupPlayer(player)
end
