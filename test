-- ─────────────────────────────────────────────
--   Pętla per-gracz (Heartbeat)
--   [FIX #1] Frame-rate independent lerp przez exp()
--   [FIX #3] Dystans zapisywany w tagData — globalLoop go odczytuje
-- ─────────────────────────────────────────────

local function startPlayerLoop(player, refs)
    local currentTrans = 1   -- zaczyna niewidoczny → ease-in
    local distTimer    = 0
    local conn

    conn = RunService.Heartbeat:Connect(function(dt)
        if not refs.billboard or not refs.billboard.Parent then
            conn:Disconnect()
            return
        end

        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        local char   = player.Character
        local head   = char and char:FindFirstChild("Head")

        if not lpRoot or not head then
            -- [FIX #1] exp() daje identyczny efekt wizualny na każdym FPS
            currentTrans = currentTrans + (1 - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
            refs.canvas.GroupTransparency = currentTrans
            return
        end

        -- Oblicz dystans raz i zapisz w tagData — globalLoop odczyta bez liczenia ponownie
        local delta = head.Position - lpRoot.Position
        local dist  = delta.Magnitude
        local data  = tagData[player]
        if data then data.cachedDist = dist end

        distTimer = distTimer + dt
        if distTimer >= CFG.DistThrottle then
            distTimer = 0
            local dc = distColor(dist)
            refs.distLabel.Text       = format("%.0f studs", dist)
            refs.distDot.TextColor3   = dc
            refs.distLabel.TextColor3 = dc
        end

        local overlapPen  = data and data.overlapTrans or 0
        local targetTrans = math.max(fadeTrans(dist), overlapPen)

        -- [FIX #1] Frame-rate independent lerp
        currentTrans = currentTrans + (targetTrans - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
        refs.canvas.GroupTransparency = currentTrans
    end)

    return conn
end

-- ─────────────────────────────────────────────
--   Globalny overlap loop (throttlowany)
--   [FIX #3] Używa cachedDist zamiast liczyć Magnitude ponownie
--   [FIX #5] Squared magnitude — brak pierwiastka dla każdej pary tagów
-- ─────────────────────────────────────────────

local function startGlobalLoop()
    if globalLoop then
        globalLoop:Disconnect()
        globalLoop = nil
    end

    local overlapTimer = 0

    globalLoop = RunService.Heartbeat:Connect(function(dt)
        overlapTimer = overlapTimer + dt
        if overlapTimer < CFG.OverlapThrottle then return end
        overlapTimer = 0

        -- Zbierz widocznych graczy z pozycją na ekranie
        local entries = {}
        for pl, data in tagData do
            if not data.refs then continue end
            local char = pl.Character
            local head = char and char:FindFirstChild("Head")
            if not head then continue end

            -- [FIX #3] Odczytaj cached dystans — Magnitude już policzony w Heartbeat
            local dist = data.cachedDist or math.huge

            table.insert(entries, {
                player    = pl,
                dist      = dist,
                screenPos = worldToScreen(head.Position + CFG.StudsOffset),
            })
        end

        -- Sortuj od najbliższego: bliższy nie jest przyciemniany przez dalszego
        table.sort(entries, function(a, b) return a.dist < b.dist end)

        -- Resetuj overlap dla wszystkich
        for _, entry in entries do
            local data = tagData[entry.player]
            if data then data.overlapTrans = 0 end
        end

        -- Wykryj nakładające się tagi
        -- [FIX #5] Porównanie kwadratem odległości — brak sqrt dla każdej pary
        for i = 1, #entries do
            local posI = entries[i].screenPos
            if not posI then continue end
            for j = i + 1, #entries do
                local posJ = entries[j].screenPos
                if not posJ then continue end

                local dx   = posI.X - posJ.X
                local dy   = posI.Y - posJ.Y
                local pxSq = dx * dx + dy * dy

                if pxSq < OVERLAP_PX_SQ then
                    local data = tagData[entries[j].player]
                    if data then
                        -- sqrt tylko gdy wiemy że para się nakłada
                        local px = math.sqrt(pxSq)
                        data.overlapTrans = math.max(
                            data.overlapTrans or 0,
                            (1 - px / CFG.OverlapPx) * CFG.OverlapBonus
                        )
                    end
                end
            end
        end
    end)
end

-- ─────────────────────────────────────────────
--   Globalny watcher — jeden task.spawn dla wszystkich graczy
--   [FIX #2] Zastępuje 50 coroutine'ów per-gracz
--   Obsługuje: brak postaci, ;char (nowy Head), brak UI przy istniejącej postaci
-- ─────────────────────────────────────────────

local function startGlobalWatcher()
    if globalWatcher then
        globalWatcher:Disconnect()
        globalWatcher = nil
    end

    -- Jeden task.spawn zamiast N coroutine'ów
    task.spawn(function()
        while enabled do
            for player, data in tagData do
                local char = player.Character
                local head = char and char:FindFirstChild("Head")

                if not char or not head then
                    -- Postać zniknęła — zniszcz UI jeśli istnieje
                    if data.refs then
                        -- destroyTagUI woła się niżej, nie możemy wywołać
                        -- przed deklaracją — używamy bezpośrednio
                        if data.heartbeat then
                            data.heartbeat:Disconnect()
                            data.heartbeat = nil
                        end
                        if data.refs.billboard and data.refs.billboard.Parent then
                            data.refs.billboard:Destroy()
                        end
                        data.refs         = nil
                        data.overlapTrans = 0
                        data.cachedDist   = nil
                    end

                elseif not data.refs or not data.refs.billboard or not data.refs.billboard.Parent then
                    -- Postać istnieje, brak UI — zbuduj (jeśli nie jest już w trakcie budowy)
                    if not data.building then
                        attachToHead(player, head)
                    end

                elseif data.refs.billboard.Adornee ~= head then
                    -- Head się zmienił (;char) — zaktualizuj Adornee
                    -- Nie przebudowujemy całego UI — wystarczy nowy Adornee
                    data.refs.billboard.Adornee = head
                end
            end

            task.wait(CFG.WatcherInterval)
        end
    end)
end

-- ─────────────────────────────────────────────
--   Lifecycle taga
-- ─────────────────────────────────────────────

local function destroyTagUI(player)
    local data = tagData[player]
    if not data then return end

    if data.heartbeat then
        data.heartbeat:Disconnect()
        data.heartbeat = nil
    end

    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        data.refs.billboard:Destroy()
    end

    data.refs         = nil
    data.overlapTrans = 0
    data.cachedDist   = nil
    data.building     = false
end

local function destroyTag(player)
    local data = tagData[player]
    if not data then return end

    destroyTagUI(player)

    if data.charConn then
        data.charConn:Disconnect()
        data.charConn = nil
    end

    -- [FIX #8] Czyszczenie widthCache przy odejściu gracza
    -- avatarCache celowo zachowujemy — gracz może wrócić i cache jest lekki
    widthCache[player.UserId] = nil

    tagData[player] = nil
end

-- ─────────────────────────────────────────────
--   Podpięcie taga pod głowę gracza
--   [FIX #4] Flaga `building` blokuje równoległe wywołania
-- ─────────────────────────────────────────────

-- Deklaracja forward — używana przez startGlobalWatcher powyżej
attachToHead = nil

attachToHead = function(player, head)
    local data = tagData[player]
    if not data or not enabled then return end
    if not head or not head.Parent then return end

    -- [FIX #4] Blokada race condition między CharacterAdded a watcherem
    if data.building then return end

    -- Jeśli billboard istnieje i ma właściwy Head — nic nie rób
    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        if data.refs.billboard.Adornee ~= head then
            data.refs.billboard.Adornee = head
        end
        return
    end

    data.building = true
    destroyTagUI(player)

    local ok, err = pcall(function()
        local refs      = buildUI(player, head)
        local heartbeat = startPlayerLoop(player, refs)
        data.refs       = refs
        data.heartbeat  = heartbeat
    end)

    data.building = false

    if not ok then
        warn("[Nametags] attachToHead [" .. player.Name .. "]: " .. tostring(err))
    end
end

-- ─────────────────────────────────────────────
--   Inicjalizacja gracza
-- ─────────────────────────────────────────────

local function setupPlayer(player)
    if player == lp then return end
    if tagData[player] then return end

    tagData[player] = {
        refs         = nil,
        heartbeat    = nil,
        charConn     = nil,
        overlapTrans = 0,
        cachedDist   = nil,
        building     = false,
    }

    local data = tagData[player]

    -- CharacterAdded: szybka ścieżka dla ;char i respawnu
    -- Globalny watcher łapie edge case gdy postać istnieje przed podpięciem
    data.charConn = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head = newChar:WaitForChild("Head", 5)
            if not head or not tagData[player] then return end
            attachToHead(player, head)
        end)
    end)

    -- Jeśli gracz już ma postać przy setupie (załadowany po `;char` lub join)
    if enabled then
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            attachToHead(player, head)
        end
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API
--   [FIX #7] Namespace getgenv().Nametags — brak kolizji z innymi skryptami
-- ─────────────────────────────────────────────

getgenv().Nametags = {

    enable = function()
        if enabled then return end   -- idempotent — brak double-start
        enabled = true

        for _, player in Players:GetPlayers() do
            if player == lp then continue end
            if not tagData[player] then
                setupPlayer(player)
            else
                -- Gracz już zainicjalizowany — spróbuj podpiąć UI jeśli ma postać
                local data = tagData[player]
                local char = player.Character
                local head = char and char:FindFirstChild("Head")
                if head and not data.refs and not data.building then
                    attachToHead(player, head)
                end
            end
        end

        startGlobalLoop()
        startGlobalWatcher()
    end,

    disable = function()
        if not enabled then return end   -- idempotent
        enabled = false

        for player, data in tagData do
            destroyTagUI(player)
        end

        if globalLoop then
            globalLoop:Disconnect()
            globalLoop = nil
        end

        -- globalWatcher jest coroutine sterowany przez flagę `enabled` —
        -- ustawienie enabled=false wystarczy żeby zakończył pętlę
        globalWatcher = nil
    end,

    -- Aktualizuje kolor akcentu na wszystkich aktywnych tagach
    setColor = function(color)
        accentColor = color
        for _, data in tagData do
            if data.refs then
                data.refs.accentBar.BackgroundColor3 = color
                data.refs.accentGrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                    ColorSequenceKeypoint.new(1, accentDark(color)),
                })
                data.refs.ring.BackgroundColor3 = color
            end
        end
    end,
}

-- Backwards-compatible aliasy (dla Rayfield toggle z v13)
getgenv().enableNametags  = getgenv().Nametags.enable
getgenv().disableNametags = getgenv().Nametags.disable
getgenv().updateNametagColor = getgenv().Nametags.setColor

