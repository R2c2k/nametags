-- ─────────────────────────────────────────────
--   Animacja masterAlpha — bezpieczna, anty-spam
-- ─────────────────────────────────────────────

local function animateMasterAlpha(targetAlpha, speed, onDone)
    if masterAlphaConn then
        masterAlphaConn:Disconnect()
        masterAlphaConn = nil
    end

    if math.abs(masterAlpha - targetAlpha) < 0.002 then
        masterAlpha = targetAlpha
        if onDone then onDone() end
        return
    end

    masterAlphaConn = RunService.Heartbeat:Connect(function(dt)
        local diff = targetAlpha - masterAlpha
        if math.abs(diff) < 0.002 then
            masterAlpha = targetAlpha
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
            if onDone then onDone() end
            return
        end
        masterAlpha = masterAlpha + diff * (1 - exp(-speed * dt))
    end)
end

-- ─────────────────────────────────────────────
--   Pętla per-gracz (Heartbeat)
-- ─────────────────────────────────────────────

local function startPlayerLoop(player, refs)
    local currentTrans = 1  -- startuje ukryty (fade-in)
    local distTimer    = 0
    local data         = tagData[player]
    local conn

    conn = RunService.Heartbeat:Connect(function(dt)
        if not refs.billboard or not refs.billboard.Parent then
            conn:Disconnect()
            return
        end

        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        local char   = player.Character
        local head   = char and char:FindFirstChild("Head")

        -- Animacja fade per-gracz (fade-in / fade-out)
        if data then
            if data.fadeState == "in" then
                data.fadeAlpha = data.fadeAlpha + (0 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeInSpeed * dt))
                if math.abs(data.fadeAlpha) < 0.005 then
                    data.fadeAlpha = 0
                    data.fadeState = "idle"
                end
            elseif data.fadeState == "out" then
                data.fadeAlpha = data.fadeAlpha + (1 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeOutSpeed * dt))
                if data.fadeAlpha > 0.995 then
                    data.fadeAlpha = 1
                    conn:Disconnect()
                    if refs.billboard and refs.billboard.Parent then
                        refs.billboard:Destroy()
                    end
                    if refs.shadowBB and refs.shadowBB.Parent then
                        refs.shadowBB:Destroy()
                    end
                    if tagData[player] and tagData[player].refs == refs then
                        tagData[player].refs      = nil
                        tagData[player].fadeState = "idle"
                        tagData[player].fadeAlpha = 1
                    end
                    return
                end
            end
        end

        local playerFade = data and data.fadeAlpha or 0

        -- Gdy brak postaci — trzymaj aktualny stan przez masterAlpha + playerFade
        if not lpRoot or not head then
            local targetTrans = math.max(masterAlpha, playerFade)
            currentTrans = currentTrans + (targetTrans - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
            if refs.canvas then refs.canvas.GroupTransparency = currentTrans end
            if refs.shadowCanvas then refs.shadowCanvas.GroupTransparency = currentTrans end
            return
        end

        -- Dystans — tylko do etykiety, NIE wpływa na alpha
        distTimer = distTimer + dt
        if distTimer >= CFG.DistThrottle then
            distTimer = 0
            local delta = head.Position - lpRoot.Position
            local dist  = delta.Magnitude
            local dc    = distColor(dist)
            refs.distLabel.Text       = format("%.0f studs", math.floor(dist))
            refs.distDot.TextColor3   = dc
            refs.distLabel.TextColor3 = dc
        end

        -- Finalna przezroczystość: tylko masterAlpha i playerFade
        local targetTrans = math.max(masterAlpha, playerFade)

        currentTrans = currentTrans + (targetTrans - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
        if refs.canvas then refs.canvas.GroupTransparency = currentTrans end
        if refs.shadowCanvas then refs.shadowCanvas.GroupTransparency = currentTrans end
    end)

    return conn
end

-- ─────────────────────────────────────────────
--   Lifecycle taga
-- ─────────────────────────────────────────────

local attachToHead  -- forward declaration

local function destroyTagUI(player)
    local data = tagData[player]
    if not data then return end

    if data.heartbeat then
        data.heartbeat:Disconnect()
        data.heartbeat = nil
    end

    if data.refs then
        if data.refs.billboard and data.refs.billboard.Parent then
            pcall(function() data.refs.billboard:Destroy() end)
        end
        if data.refs.shadowBB and data.refs.shadowBB.Parent then
            pcall(function() data.refs.shadowBB:Destroy() end)
        end
    end

    data.refs      = nil
    data.building  = false
    data.fadeState = "idle"
    data.fadeAlpha = 1
end

local function destroyTagUIWithFade(player)
    local data = tagData[player]
    if not data or not data.refs then
        destroyTagUI(player)
        return
    end
    data.fadeState = "out"
    data.fadeAlpha = math.min(data.fadeAlpha or 0, 0.99)
end

local function destroyTag(player)
    local data = tagData[player]
    if not data then return end

    if data.refs and data.heartbeat then
        destroyTagUIWithFade(player)
        task.delay(1.5, function()
            if tagData[player] then
                if data.heartbeat then data.heartbeat:Disconnect(); data.heartbeat = nil end
                if data.charConn  then data.charConn:Disconnect();  data.charConn  = nil end
                widthCache[player.UserId] = nil
                tagData[player] = nil
            end
        end)
    else
        destroyTagUI(player)
        if data.charConn then
            data.charConn:Disconnect()
            data.charConn = nil
        end
        widthCache[player.UserId] = nil
        tagData[player] = nil
    end
end

-- ─────────────────────────────────────────────
--   Globalny watcher
-- ─────────────────────────────────────────────

local function startGlobalWatcher()
    if globalWatcher then
        task.cancel(globalWatcher)
        globalWatcher = nil
    end

    globalWatcher = task.spawn(function()
        while enabled do
            for player, data in tagData do
                if data.fadeState == "out" then continue end

                local char = player.Character
                local head = char and char:FindFirstChild("Head")

                if not char or not head then
                    if data.refs then
                        if data.heartbeat then
                            data.heartbeat:Disconnect()
                            data.heartbeat = nil
                        end
                        if data.refs.billboard and data.refs.billboard.Parent then
                            pcall(function() data.refs.billboard:Destroy() end)
                        end
                        if data.refs.shadowBB and data.refs.shadowBB.Parent then
                            pcall(function() data.refs.shadowBB:Destroy() end)
                        end
                        data.refs      = nil
                        data.fadeState = "idle"
                        data.fadeAlpha = 1
                    end

                elseif not data.refs or not data.refs.billboard or not data.refs.billboard.Parent then
                    if not data.building then
                        attachToHead(player, head)
                    end

                elseif data.refs.billboard.Adornee ~= head then
                    data.refs.billboard.Adornee = head
                    if data.refs.shadowBB then
                        data.refs.shadowBB.Adornee = head
                    end
                end
            end

            task.wait(CFG.WatcherInterval)
        end
    end)
end

-- ─────────────────────────────────────────────
--   Podpięcie taga pod głowę
-- ─────────────────────────────────────────────

attachToHead = function(player, head)
    local data = tagData[player]
    if not data or not enabled then return end
    if not head or not head.Parent then return end
    if data.building then return end

    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        if data.refs.billboard.Adornee ~= head then
            data.refs.billboard.Adornee = head
            if data.refs.shadowBB then
                data.refs.shadowBB.Adornee = head
            end
        end
        return
    end

    data.building = true
    destroyTagUI(player)

    data.fadeState = "in"
    data.fadeAlpha = 1

    local ok, err = pcall(function()
        local refs      = buildUI(player, head)
        local heartbeat = startPlayerLoop(player, refs)
        data.refs       = refs
        data.heartbeat  = heartbeat
    end)

    data.building = false

    if not ok then
        warn("[Nametags] attachToHead [" .. player.Name .. "]: " .. tostring(err))
    end
end

-- ─────────────────────────────────────────────
--   Inicjalizacja gracza
-- ─────────────────────────────────────────────

local function setupPlayer(player)
    if player == lp then return end
    if tagData[player] then return end

    tagData[player] = {
        refs       = nil,
        heartbeat  = nil,
        charConn   = nil,
        fadeState  = "idle",
        fadeAlpha  = 1,
        building   = false,
    }

    local data = tagData[player]

    data.charConn = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head = newChar:WaitForChild("Head", 5)
            if not head or not tagData[player] then return end
            attachToHead(player, head)
        end)
    end)

    if enabled then
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            data.fadeState = "in"
            data.fadeAlpha = 1
            attachToHead(player, head)
        end
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API
-- ─────────────────────────────────────────────

getgenv().Nametags = {

    enable = function()
        if enabled and not isTransitioning then return end

        isTransitioning = true
        enabled = true

        for _, player in Players:GetPlayers() do
            if player == lp then continue end
            if not tagData[player] then
                setupPlayer(player)
            else
                local data = tagData[player]
                if data.fadeState == "out" then
                    data.fadeState = "in"
                end
                local char = player.Character
                local head = char and char:FindFirstChild("Head")
                if head and not data.refs and not data.building then
                    data.fadeState = "in"
                    data.fadeAlpha = 1
                    attachToHead(player, head)
                end
            end
        end

        startGlobalWatcher()

        animateMasterAlpha(0, CFG.ToggleLerpSpeed, function()
            isTransitioning = false
        end)
    end,

    disable = function()
        if not enabled and not isTransitioning then return end

        isTransitioning = true

        animateMasterAlpha(1, CFG.ToggleLerpSpeed, function()
            if enabled then
                isTransitioning = false
                return
            end

            isTransitioning = false

            for player, _ in tagData do
                destroyTagUI(player)
            end

            if globalWatcher then
                task.cancel(globalWatcher)
                globalWatcher = nil
            end
        end)

        enabled = false
    end,

    setColor = function(color)
        accentColor = color
        for _, data in tagData do
            if data.refs then
                data.refs.accentBar.BackgroundColor3 = color
                data.refs.accentGrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                    ColorSequenceKeypoint.new(1, accentDark(color)),
                })
                data.refs.ring.BackgroundColor3 = color
            end
        end
    end,
}

getgenv().enableNametags     = getgenv().Nametags.enable
getgenv().disableNametags    = getgenv().Nametags.disable
getgenv().updateNametagColor = getgenv().Nametags.setColor

-- ─────────────────────────────────────────────
--   Zdarzenia
-- ─────────────────────────────────────────────

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(player)
    local data = tagData[player]
    if data and data.refs and data.heartbeat then
        data.fadeState = "out"
        data.fadeAlpha = data.fadeAlpha or 0
        task.delay(1.5, function()
            if tagData[player] then
                if data.heartbeat then data.heartbeat:Disconnect(); data.heartbeat = nil end
                if data.charConn  then data.charConn:Disconnect();  data.charConn  = nil end
                widthCache[player.UserId] = nil
                tagData[player] = nil
            end
        end)
    else
        if tagData[player] then
            destroyTagUI(player)
            if data and data.charConn then
                data.charConn:Disconnect()
            end
            widthCache[player.UserId] = nil
            tagData[player] = nil
        end
    end
end)

for _, player in Players:GetPlayers() do
    setupPlayer(player)
end
