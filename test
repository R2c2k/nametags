local exp=math.exp, abs=math.abs, clamp=math.clamp
local floor=math.floor, max=math.max, format=string.format

local function lerpColor(c1,c2,t)
    return Color3.new(c1.R+(c2.R-c1.R)*t, c1.G+(c2.G-c1.G)*t, c1.B+(c2.B-c1.B)*t)
end

local function distColor(d)
    local close,far=CFG.DistClose,CFG.DistFar
    local mid=(close+far)*0.5
    if d<=close then return CFG.ColorClose
    elseif d<=mid then return lerpColor(CFG.ColorClose,CFG.ColorMid,(d-close)/(mid-close))
    elseif d<=far then return lerpColor(CFG.ColorMid,CFG.ColorFar,(d-mid)/(far-mid))
    else return CFG.ColorFar end
end

local function accentGradientColor(color)
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.new(math.min(color.R*1.35,1),math.min(color.G*1.35,1),math.min(color.B*1.35,1))),
        ColorSequenceKeypoint.new(1,Color3.new(color.R*0.55,color.G*0.55,color.B*0.55)),
    })
end

local function calcWidth(player)
    local uid=player.UserId
    if widthCache[uid] then return widthCache[uid] end
    local dn=player.DisplayName, un=player.Name
    local ao=CFG.AvatarSize+18
    local bb=Vector2.new(9999,16), sb=Vector2.new(9999,13)
    local w=math.max(
        TextService:GetTextSize(dn,11,CFG.FontMain,bb).X,
        TextService:GetTextSize("@"..un,9,CFG.FontSub,sb).X,
        TextService:GetTextSize("999 studs",8,CFG.FontMeta,sb).X
    )
    local r=clamp(ao+w+CFG.WidthPadR,CFG.WidthMin,CFG.WidthMax)
    widthCache[uid]=r
    return r
end

local function findHead(player)
    local char=player.Character
    if not char then return nil end
    local h=char:FindFirstChild("Head")
    if h then return h end
    for _,v in ipairs(char:GetDescendants()) do
        if v:IsA("BasePart") and v.Name=="Head" then return v end
    end
    return nil
end

