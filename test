-- ─────────────────────────────────────────────
--   [A1] Animacja globalnego toggle
--   masterAlpha: 1 = ukryte, 0 = widoczne
--   Per-player loop: finalTrans = max(playerTrans, masterAlpha)
-- ─────────────────────────────────────────────

local function animateMasterAlpha(targetAlpha, speed, onDone)
    if masterAlphaConn then
        masterAlphaConn:Disconnect()
        masterAlphaConn = nil
    end

    masterAlphaConn = RunService.Heartbeat:Connect(function(dt)
        local diff = targetAlpha - masterAlpha
        -- Zatrzymaj gdy wystarczająco blisko
        if math.abs(diff) < 0.002 then
            masterAlpha = targetAlpha
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
            if onDone then onDone() end
            return
        end
        masterAlpha = masterAlpha + diff * (1 - exp(-speed * dt))
    end)
end

-- ─────────────────────────────────────────────
--   Pętla per-gracz (Heartbeat)
--   [A2] fadeAlpha: oddzielna alfa fade-in/out per gracz
--   [A4] camDist przekazywany do fadeTrans
-- ─────────────────────────────────────────────

local function startPlayerLoop(player, refs)
    local currentTrans = 1
    local distTimer    = 0
    local data         = tagData[player]
    local conn

    conn = RunService.Heartbeat:Connect(function(dt)
        if not refs.billboard or not refs.billboard.Parent then
            conn:Disconnect()
            return
        end

        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        local char   = player.Character
        local head   = char and char:FindFirstChild("Head")

        -- [A2][A3] Animacja fade-in / fade-out per gracz
        if data then
            if data.fadeState == "in" then
                data.fadeAlpha = data.fadeAlpha + (0 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeInSpeed * dt))
                if math.abs(data.fadeAlpha) < 0.005 then
                    data.fadeAlpha = 0
                    data.fadeState = "idle"
                end
            elseif data.fadeState == "out" then
                data.fadeAlpha = data.fadeAlpha + (1 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeOutSpeed * dt))
                if data.fadeAlpha > 0.995 then
                    data.fadeAlpha = 1
                    -- Zniszcz UI po zakończeniu fade-out
                    conn:Disconnect()
                    if refs.billboard and refs.billboard.Parent then
                        refs.billboard:Destroy()
                    end
                    if refs.shadowBB and refs.shadowBB.Parent then
                        refs.shadowBB:Destroy()
                    end
                    if data.refs == refs then
                        data.refs         = nil
                        data.fadeState    = "idle"
                        data.overlapTrans = 0
                        data.cachedDist   = nil
                    end
                    return
                end
            end
        end

        local playerFade = data and data.fadeAlpha or 0

        if not lpRoot or not head then
            local targetTrans = math.max(1, masterAlpha, playerFade)
            currentTrans = currentTrans + (targetTrans - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
            refs.canvas.GroupTransparency      = currentTrans
            refs.shadowCanvas.GroupTransparency = currentTrans
            return
        end

        local delta = head.Position - lpRoot.Position
        local dist  = delta.Magnitude
        if data then data.cachedDist = dist end

        -- [A4] Dystans kamera od gracza
        local camPos  = Camera.CFrame.Position
        local camDist = (camPos - head.Position).Magnitude

        distTimer = distTimer + dt
        if distTimer >= CFG.DistThrottle then
            distTimer = 0
            local dc = distColor(dist)
            refs.distLabel.Text       = format("%.0f studs", math.floor(dist))
            refs.distDot.TextColor3   = dc
            refs.distLabel.TextColor3 = dc
        end

        local overlapPen  = data and data.overlapTrans or 0
        -- [A4] camDist w fadeTrans
        local baseTarget  = math.max(fadeTrans(dist, camDist), overlapPen)

        -- [A1][A2][A3] Finalna przezroczystość: max z wszystkich warstw
        local targetTrans = math.max(baseTarget, masterAlpha, playerFade)

        currentTrans = currentTrans + (targetTrans - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
        refs.canvas.GroupTransparency       = currentTrans
        refs.shadowCanvas.GroupTransparency = currentTrans
    end)

    return conn
end

-- ─────────────────────────────────────────────
--   Globalny overlap loop
-- ─────────────────────────────────────────────

local function startGlobalLoop()
    if globalLoop then
        globalLoop:Disconnect()
        globalLoop = nil
    end

    local overlapTimer = 0

    globalLoop = RunService.Heartbeat:Connect(function(dt)
        overlapTimer = overlapTimer + dt
        if overlapTimer < CFG.OverlapThrottle then return end
        overlapTimer = 0

        local entries = {}
        for pl, data in tagData do
            if not data.refs then continue end
            local char = pl.Character
            local head = char and char:FindFirstChild("Head")
            if not head then continue end

            local dist = data.cachedDist or math.huge
            local sp   = worldToScreen(head.Position + CFG.StudsOffset)
            if not sp then continue end

            table.insert(entries, {
                player    = pl,
                dist      = dist,
                screenPos = sp,
            })
        end

        table.sort(entries, function(a, b) return a.dist < b.dist end)

        for _, entry in entries do
            local data = tagData[entry.player]
            if data then data.overlapTrans = 0 end
        end

        for i = 1, #entries do
            local posI = entries[i].screenPos
            for j = i + 1, #entries do
                local posJ = entries[j].screenPos
                local dx   = posI.X - posJ.X
                local dy   = posI.Y - posJ.Y
                local pxSq = dx * dx + dy * dy

                if pxSq < OVERLAP_PX_SQ then
                    local data = tagData[entries[j].player]
                    if data then
                        local px = math.sqrt(pxSq)
                        data.overlapTrans = math.max(
                            data.overlapTrans or 0,
                            (1 - px / CFG.OverlapPx) * CFG.OverlapBonus
                        )
                    end
                end
            end
        end
    end)
end

