-- ─────────────────────────────────────────────

local function startGlobalHeartbeat()
    if globalHeartbeat then
        globalHeartbeat:Disconnect()
        globalHeartbeat = nil
    end

    -- [PERF] lpRoot cachowany między klatkami
    -- Aktualizowany tylko gdy lp.Character się zmienia, nie co klatkę
    local cachedLpRoot  = nil
    local lpCharConn    = nil

    local function updateLpRoot()
        local char = lp.Character
        cachedLpRoot = char and char:FindFirstChild("HumanoidRootPart") or nil
    end

    updateLpRoot()

    -- Śledź zmiany postaci lokalnego gracza
    if lpCharConn then lpCharConn:Disconnect() end
    lpCharConn = lp.CharacterAdded:Connect(function(newChar)
        -- Poczekaj chwilę na HRP
        task.delay(0.1, function()
            cachedLpRoot = newChar:FindFirstChild("HumanoidRootPart")
        end)
    end)
    lp.CharacterRemoving:Connect(function()
        cachedLpRoot = nil
    end)

    globalHeartbeat = RunService.Heartbeat:Connect(function(dt)
        local lpRoot = cachedLpRoot

        for player, data in tagData do
            if not data.refs then continue end

            local refs = data.refs

            -- Billboard zniknął z kontenera (np. przez zewnętrzny skrypt)
            if not refs.billboard or not refs.billboard.Parent then
                data.refs         = nil
                data.fadeState    = "idle"
                data.fadeAlpha    = 1
                data.currentTrans = 1
                data.building     = false
                data.rebuildPending = false
                continue
            end

            -- ── Zombie adornee detection ──────────────────────────────────
            -- [PERF] isAlive zamiast pcall — zero alokacji na klatkę
            -- Billboard żyje w kontenerze ale Adornee to zniszczony Head
            -- (po ;char / ;re / ;wormify / ;spongify itd.)
            -- Roblox ukrywa BillboardGui gdy Adornee.Parent == nil
            -- [FIX] rebuildPending zapobiega wielokrotnemu task.spawn
            -- zanim poprzedni zdąży ustawić data.building = true
            do
                local adornee   = refs.billboard.Adornee
                local adorneeOk = isAlive(adornee)

                if not adorneeOk and not data.rebuildPending then
                    local char        = player.Character
                    local currentHead = char and char:FindFirstChild("Head")

                    -- Zniszcz zombie billboard
                    if refs.billboard.Parent then
                        pcall(function() refs.billboard:Destroy() end)
                    end
                    if refs.shadowBB and refs.shadowBB.Parent then
                        pcall(function() refs.shadowBB:Destroy() end)
                    end
                    data.refs     = nil
                    data.building = false

                    if currentHead and enabled then
                        -- [FIX] Ustaw pending PRZED task.spawn
                        -- żeby kolejna klatka HB nie odpalila drugiego spawna
                        data.rebuildPending = true
                        data.fadeState      = "in"
                        data.fadeAlpha      = 1
                        data.currentTrans   = 1

                        task.spawn(function()
                            -- [FIX] Sprawdź tokeny przed rebuildem
                            if not tagData[player] then return end
                            if not enabled then return end
                            -- rebuildPending wyczyści attachToHead
                            attachToHead(player, currentHead, false)
                        end)
                    else
                        data.rebuildPending = false
                        data.fadeState      = "idle"
                        data.fadeAlpha      = 1
                        data.currentTrans   = 1
                    end
                    continue
                end

                -- Adornee zombie ale pending już jest — po prostu pomiń tę klatkę
                if not adorneeOk then continue end
            end
            -- ─────────────────────────────────────────────────────────────

            local fadeState = data.fadeState

            if fadeState == "in" then
                data.fadeAlpha = data.fadeAlpha + (0 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeInSpeed * dt))
                if abs(data.fadeAlpha) < 0.005 then
                    data.fadeAlpha = 0
                    data.fadeState = "idle"
                end

            elseif fadeState == "out" then
                data.fadeAlpha = data.fadeAlpha + (1 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeOutSpeed * dt))
                if data.fadeAlpha > 0.995 then
                    data.fadeAlpha    = 1
                    data.fadeState    = "idle"
                    data.currentTrans = 1
                    if refs.billboard and refs.billboard.Parent then
                        pcall(function() refs.billboard:Destroy() end)
                    end
                    if refs.shadowBB and refs.shadowBB.Parent then
                        pcall(function() refs.shadowBB:Destroy() end)
                    end
                    data.refs = nil
                    continue
                end
            end

            -- Finalny alpha = max(masterAlpha, fadeAlpha)
            local finalTrans
            if fadeState == "idle" then
                finalTrans        = masterAlpha
                data.currentTrans = finalTrans
            else
                local targetTrans = max(masterAlpha, data.fadeAlpha)
                local cur         = data.currentTrans
                cur               = cur + (targetTrans - cur) * (1 - exp(-CFG.LerpSpeed * dt))
                data.currentTrans = cur
                finalTrans        = cur
            end

            refs.canvas.GroupTransparency       = finalTrans
            refs.shadowCanvas.GroupTransparency = finalTrans

            -- ── Dystans ──────────────────────────────────────────────────
            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if lpRoot and head then
                data.distTimer = (data.distTimer or 0) + dt
                if data.distTimer >= CFG.DistThrottle then
                    data.distTimer = 0
                    local dist = (head.Position - lpRoot.Position).Magnitude
                    local dc   = distColor(dist)
                    refs.distLabel.Text       = format("%.0f studs", floor(dist))
                    refs.distDot.TextColor3   = dc
                    refs.distLabel.TextColor3 = dc
                end
            end
        end
    end)
end

-- ─────────────────────────────────────────────
--   Cleanup gracza
-- ─────────────────────────────────────────────

local function cleanupPlayer(player)
    local data = tagData[player]
    if not data then return end

    if data.charConns then
        for _, conn in data.charConns do
            pcall(function() conn:Disconnect() end)
        end
        data.charConns = nil
    end

    destroyTagUI(player, false)

    widthCache[player.UserId] = nil
    tagData[player] = nil
end

-- ─────────────────────────────────────────────
--   Setup gracza
-- ─────────────────────────────────────────────

local function setupPlayer(player)
    if player == lp then return end
    if tagData[player] then return end

    tagData[player] = {
        refs            = nil,
        charConns       = nil,
        fadeState       = "idle",
        fadeAlpha       = 1,
        building        = false,
        rebuildPending  = false,
        distTimer       = 0,
        currentTrans    = 1,
        _buildToken     = nil,
    }

    local data = tagData[player]

    local charAdded = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head = newChar:WaitForChild("Head", 5)
            if not head or not tagData[player] then return end
            if not enabled then return end

            -- [FIX] Guard: przy błyskawicznym podwójnym respawnie
            -- (;char → ;re w <0.1s) stary callback nie nadpisze nowego
            if player.Character ~= newChar then return end

            attachToHead(player, head, false)
        end)
    end)

    local charRemoving = player.CharacterRemoving:Connect(function()
        local d = tagData[player]
        if not d then return end
        if d.refs then
            d.fadeState = "out"
        end
        -- Reset pending — nowa postać jeszcze nie istnieje
        d.rebuildPending = false
    end)

    data.charConns = { charAdded, charRemoving }

    -- Jeśli nametagi już włączone i gracz ma postać — podepnij od razu
    if enabled then
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            attachToHead(player, head, false)
        end
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API
-- ─────────────────────────────────────────────

getgenv().Nametags = {

    enable = function()
        if enabled and not isTransitioning then return end

        isTransitioning = true
        enabled = true

        if masterAlphaConn then
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
        end
        masterAlpha = 1

        startGlobalHeartbeat()

        for _, player in Players:GetPlayers() do
            if player == lp then continue end

            if not tagData[player] then
                setupPlayer(player)
            end

            local data = tagData[player]
            if not data then continue end
            if data.fadeState == "out" then continue end

            -- [FIX] Resetuj building przy enable — zapobiega
            -- sytuacji gdy poprzednie wywołanie skończyło się z building=true
            data.building       = false
            data.rebuildPending = false
            data.fadeState      = "idle"
            data.fadeAlpha      = 0
            data.currentTrans   = 1

            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if head then
                attachToHead(player, head, true)
            elseif data.refs then
                data.refs.canvas.GroupTransparency       = 1
                data.refs.shadowCanvas.GroupTransparency = 1
                data.currentTrans = 1
            end
        end

        animateMasterAlpha(0, CFG.ToggleLerpSpeed, function()
            isTransitioning = false
        end)
    end,

    disable = function()
        if not enabled and not isTransitioning then return end

        enabled = false
        isTransitioning = true

        for _, data in tagData do
            if data.fadeState == "in" then
                data.fadeState = "idle"
                data.fadeAlpha = 0
            end
            data.rebuildPending = false
        end

        animateMasterAlpha(1, CFG.ToggleLerpSpeed, function()
            isTransitioning = false

            if globalHeartbeat then
                globalHeartbeat:Disconnect()
                globalHeartbeat = nil
            end

            for player, _ in tagData do
                destroyTagUI(player, false)
            end

            widthCache = {}
        end)
    end,

    setColor = function(color)
        accentColor = color
        local newGradient = accentGradientColor(color)
        for _, data in tagData do
            if data.refs then
                local refs = data.refs
                refs.accentBar.BackgroundColor3 = color
                refs.accentGrad.Color           = newGradient
                refs.ring.BackgroundColor3      = color
            end
        end
    end,
}

getgenv().enableNametags     = getgenv().Nametags.enable
getgenv().disableNametags    = getgenv().Nametags.disable
getgenv().updateNametagColor = getgenv().Nametags.setColor

-- ─────────────────────────────────────────────
--   Inicjalizacja
-- ─────────────────────────────────────────────

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(player)
    local data = tagData[player]
    if not data then return end

    if data.refs then
        destroyTagUI(player, true)
        task.delay(1.2, function()
            cleanupPlayer(player)
        end)
    else
        cleanupPlayer(player)
    end
end)

for _, player in Players:GetPlayers() do
    setupPlayer(player)
end
