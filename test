-- ─────────────────────────────────────────────
--   Animacja masterAlpha — bezpieczna, anty-spam
-- ─────────────────────────────────────────────

local function animateMasterAlpha(targetAlpha, speed, onDone)
    if masterAlphaConn then
        masterAlphaConn:Disconnect()
        masterAlphaConn = nil
    end

    if abs(masterAlpha - targetAlpha) < 0.002 then
        masterAlpha = targetAlpha
        if onDone then onDone() end
        return
    end

    masterAlphaConn = RunService.Heartbeat:Connect(function(dt)
        local diff = targetAlpha - masterAlpha
        if abs(diff) < 0.002 then
            masterAlpha = targetAlpha
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
            if onDone then onDone() end
            return
        end
        masterAlpha = masterAlpha + diff * (1 - exp(-speed * dt))
    end)
end

-- ─────────────────────────────────────────────
--   Niszczenie UI taga
--   withFade: true  = płynny fade-out przed destroy
--            false = natychmiastowe usunięcie
-- ─────────────────────────────────────────────

local function destroyTagUI(player, withFade)
    local data = tagData[player]
    if not data then return end

    if withFade and data.refs then
        -- Tylko ustaw fadeState, globalna pętla HB ogarnie resztę
        data.fadeState = "out"
        data.fadeAlpha = data.fadeAlpha < 0.99 and data.fadeAlpha or 0
    else
        -- Natychmiastowe zniszczenie
        if data.refs then
            if data.refs.billboard and data.refs.billboard.Parent then
                pcall(function() data.refs.billboard:Destroy() end)
            end
            if data.refs.shadowBB and data.refs.shadowBB.Parent then
                pcall(function() data.refs.shadowBB:Destroy() end)
            end
            data.refs = nil
        end
        data.fadeState = "idle"
        data.fadeAlpha = 1
        data.building  = false
    end
end

-- ─────────────────────────────────────────────
--   Podpięcie taga pod głowę
--   toggleBuild: true = budujemy podczas toggle enable
--                      → startujemy z masterAlpha, brak własnego fade-in
--               false = normalny spawn postaci
--                      → startujemy z 1, własny fade-in
-- ─────────────────────────────────────────────

local function attachToHead(player, head, toggleBuild)
    local data = tagData[player]
    if not data or not enabled then return end
    if not head or not head.Parent then return end
    if data.building then return end
    if data.fadeState == "out" then return end

    -- Jeśli tag już istnieje na tej głowie — tylko aktualizuj adornee
    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        if data.refs.billboard.Adornee ~= head then
            data.refs.billboard.Adornee = head
            if data.refs.shadowBB then
                data.refs.shadowBB.Adornee = head
            end
        end
        return
    end

    data.building = true

    -- Zniszcz stary UI jeśli coś zostało
    destroyTagUI(player, false)

    if toggleBuild then
        data.fadeState = "idle"
        data.fadeAlpha = 0
    else
        data.fadeState = "in"
        data.fadeAlpha = 1
    end

    -- initialTrans: toggleBuild → startujemy z aktualnego masterAlpha (brak skoku)
    --               spawn       → startujemy z 1 (własny fade-in)
    local initTrans = toggleBuild and masterAlpha or 1

    local ok, err = pcall(function()
        local refs = buildUI(player, head)

        -- Ustaw GroupTransparency natychmiast zanim globalny HB zdąży iterować
        refs.canvas.GroupTransparency      = initTrans
        refs.shadowCanvas.GroupTransparency = initTrans

        -- Zapisz initTrans do danych (używane przez globalny HB)
        data.currentTrans = initTrans
        data.refs = refs
    end)

    data.building = false

    if not ok then
        warn("[Nametags] attachToHead [" .. player.Name .. "]: " .. tostring(err))
    end
end

-- ─────────────────────────────────────────────
--   Globalna pętla Heartbeat
--   JEDNA dla wszystkich graczy — zamiast N osobnych
-- ─────────────────────────────────────────────

local function startGlobalHeartbeat()
    if globalHeartbeat then
        globalHeartbeat:Disconnect()
        globalHeartbeat = nil
    end

    globalHeartbeat = RunService.Heartbeat:Connect(function(dt)
        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")

        for player, data in tagData do
            if not data.refs then continue end

            local refs = data.refs
            if not refs.billboard or not refs.billboard.Parent then
                -- Billboard zniknął z zewnątrz — wyczyść refs
                data.refs      = nil
                data.fadeState = "idle"
                data.fadeAlpha = 1
                data.currentTrans = 1
                continue
            end

            -- ── Per-player fade (spawn/despawn) ──
            local playerFade = 0
            local fadeState  = data.fadeState

            if fadeState == "in" then
                data.fadeAlpha = data.fadeAlpha + (0 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeInSpeed * dt))
                if abs(data.fadeAlpha) < 0.005 then
                    data.fadeAlpha = 0
                    data.fadeState = "idle"
                end
                playerFade = data.fadeAlpha

            elseif fadeState == "out" then
                data.fadeAlpha = data.fadeAlpha + (1 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeOutSpeed * dt))
                if data.fadeAlpha > 0.995 then
                    -- Fade-out zakończony — zniszcz UI
                    data.fadeAlpha = 1
                    data.fadeState = "idle"
                    data.currentTrans = 1
                    if refs.billboard and refs.billboard.Parent then
                        pcall(function() refs.billboard:Destroy() end)
                    end
                    if refs.shadowBB and refs.shadowBB.Parent then
                        pcall(function() refs.shadowBB:Destroy() end)
                    end
                    data.refs = nil
                    continue
                end
                playerFade = data.fadeAlpha
            end
            -- fadeState == "idle" → playerFade = 0, masterAlpha rządzi

            -- ── Dystans ───────────────────────────
            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if lpRoot and head then
                data.distTimer = (data.distTimer or 0) + dt
                if data.distTimer >= CFG.DistThrottle then
                    data.distTimer = 0
                    local dist = (head.Position - lpRoot.Position).Magnitude
                    local dc   = distColor(dist)
                    refs.distLabel.Text       = format("%.0f studs", floor(dist))
                    refs.distDot.TextColor3   = dc
                    refs.distLabel.TextColor3 = dc
                end
            end

            -- ── Finalna przezroczystość ────────────
            -- max: gdy masterAlpha = 1 (ukryty) LUB playerFade = 1 → ukryty
            local targetTrans    = masterAlpha > playerFade and masterAlpha or playerFade
            local currentTrans   = data.currentTrans or targetTrans
            currentTrans         = currentTrans + (targetTrans - currentTrans) * (1 - exp(-CFG.LerpSpeed * dt))
            data.currentTrans    = currentTrans

            refs.canvas.GroupTransparency      = currentTrans
            refs.shadowCanvas.GroupTransparency = currentTrans
        end
    end)
end

-- ─────────────────────────────────────────────
--   Inicjalizacja / cleanup gracza
-- ─────────────────────────────────────────────

local function cleanupPlayer(player)
    local data = tagData[player]
    if not data then return end

    -- Rozłącz eventy postaci
    if data.charConns then
        for _, conn in data.charConns do
            conn:Disconnect()
        end
        data.charConns = nil
    end

    -- Zniszcz UI natychmiast (nie fade — gracz wychodzi)
    destroyTagUI(player, false)

    widthCache[player.UserId] = nil
    tagData[player] = nil
end

local function setupPlayer(player)
    if player == lp then return end
    if tagData[player] then return end

    tagData[player] = {
        refs       = nil,
        charConns  = nil,
        fadeState  = "idle",
        fadeAlpha  = 1,
        building   = false,
        distTimer  = 0,
        currentTrans = 1,
    }

    local data = tagData[player]

    local charAdded = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head = newChar:WaitForChild("Head", 5)
            if not head or not tagData[player] then return end
            -- Zawsze normalny fade-in przy spawnie postaci
            attachToHead(player, head, false)
        end)
    end)

    -- CharacterRemoving — od razu fade-out przy despawnie
    local charRemoving = player.CharacterRemoving:Connect(function()
        local d = tagData[player]
        if d and d.refs then
            d.fadeState = "out"
            d.fadeAlpha = d.fadeAlpha < 0.99 and d.fadeAlpha or 0
        end
    end)

    data.charConns = { charAdded, charRemoving }

    -- Jeśli postać już istnieje w momencie setupu
    if enabled then
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            data.fadeState = "in"
            data.fadeAlpha = 1
            attachToHead(player, head, false)
        end
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API
-- ─────────────────────────────────────────────

getgenv().Nametags = {

    enable = function()
        if enabled and not isTransitioning then return end

        isTransitioning = true
        enabled = true

        -- Zatrzymaj animację masterAlpha jeśli trwa
        if masterAlphaConn then
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
        end
        -- Zresetuj masterAlpha do 1 (wszystko ukryte) — brak flasha
        masterAlpha = 1

        -- Zainicjalizuj globalną pętlę HB (jedna dla wszystkich)
        startGlobalHeartbeat()

        -- Zbuduj UI dla wszystkich obecnych graczy synchronicznie
        -- Wszystkie tagi startują z GroupTransparency = 1
        -- a masterAlpha animuje je razem do 0
        for _, player in Players:GetPlayers() do
            if player == lp then continue end

            -- Upewnij się że gracz ma wpis w tagData
            if not tagData[player] then
                setupPlayer(player)
            end

            local data = tagData[player]
            if not data then continue end
            if data.fadeState == "out" then continue end

            -- Ustaw idle → masterAlpha steruje wszystkim
            data.fadeState   = "idle"
            data.fadeAlpha   = 0
            data.currentTrans = 1

            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if head and not data.building then
                -- Buduj z initTrans = 1, fadeState = "idle"
                -- (toggleBuild = true → brak per-player fade-in, masterAlpha ciągnie wszystkich)
                attachToHead(player, head, true)
            elseif data.refs then
                -- Tag już istnieje — upewnij się że jest ukryty przed animacją
                data.refs.canvas.GroupTransparency      = 1
                data.refs.shadowCanvas.GroupTransparency = 1
                data.currentTrans = 1
            end
        end

        -- Wszyscy gotowi i ukryci — odpal fade-in przez masterAlpha
        animateMasterAlpha(0, CFG.ToggleLerpSpeed, function()
            isTransitioning = false
        end)
    end,

    disable = function()
        -- Poprawiona kolejność: najpierw enabled = false,
        -- potem animacja — callback wie że system jest wyłączony
        if not enabled and not isTransitioning then return end

        enabled = false
        isTransitioning = true

        -- Wszystkie per-player fade-in'y zatrzymaj
        -- żeby masterAlpha był jedynym sterującym podczas fade-out
        for _, data in tagData do
            if data.fadeState == "in" then
                data.fadeState = "idle"
                data.fadeAlpha = 0
            end
        end

        animateMasterAlpha(1, CFG.ToggleLerpSpeed, function()
            isTransitioning = false

            -- Zatrzymaj globalny HB
            if globalHeartbeat then
                globalHeartbeat:Disconnect()
                globalHeartbeat = nil
            end

            -- Zniszcz wszystkie UI
            for player, _ in tagData do
                destroyTagUI(player, false)
            end

            -- Wyczyść widthCache przy pełnym disable
            widthCache = {}
        end)
    end,

    setColor = function(color)
        accentColor = color
        for _, data in tagData do
            if data.refs then
                local refs = data.refs
                refs.accentBar.BackgroundColor3 = color
                refs.accentGrad.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                    ColorSequenceKeypoint.new(1, accentDark(color)),
                })
                refs.ring.BackgroundColor3 = color
            end
        end
    end,
}

