-- Cache szerokości: userId -> liczba px
-- [FIX #6] Klucz po UserId zamiast "DisplayName|UserName" —
-- bezpieczne gdy gracz zmieni DisplayName między sesjami
local widthCache = {}

-- Dane per gracz:
--   refs         : tabela referencji do elementów UI
--   heartbeat    : RBXScriptConnection pętli per-gracz
--   charConn     : RBXScriptConnection na CharacterAdded
--   overlapTrans : kara przezroczystości od nakładania się tagów (0–1)
--   cachedDist   : ostatni zmierzony dystans [FIX #3]
