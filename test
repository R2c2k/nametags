local function animateMasterAlpha(targetAlpha,speed,onDone)
    if masterAlphaConn then masterAlphaConn:Disconnect() masterAlphaConn=nil end
    if abs(masterAlpha-targetAlpha)<0.002 then
        masterAlpha=targetAlpha
        if onDone then onDone() end
        return
    end
    masterAlphaConn=RunService.Heartbeat:Connect(function(dt)
        local diff=targetAlpha-masterAlpha
        if abs(diff)<0.002 then
            masterAlpha=targetAlpha
            masterAlphaConn:Disconnect()
            masterAlphaConn=nil
            if onDone then onDone() end
            return
        end
        masterAlpha=masterAlpha+diff*(1-exp(-speed*dt))
    end)
end

local function destroyTagUI(player,withFade)
    local data=tagData[player]
    if not data then return end
    if withFade and data.refs then
        data.fadeState="out"
    else
        if data.refs then
            if data.refs.billboard and data.refs.billboard.Parent then
                pcall(function() data.refs.billboard:Destroy() end)
            end
            if data.refs.shadowBB and data.refs.shadowBB.Parent then
                pcall(function() data.refs.shadowBB:Destroy() end)
            end
            data.refs=nil
        end
        data.fadeState="idle"
        data.fadeAlpha=1
        data.currentTrans=1
        data.building=false
    end
end

local function attachToHead(player,head,toggleBuild)
    local data=tagData[player]
    if not data or not enabled then return end
    if not head or not head.Parent then return end
    if data.building then return end
    if data.fadeState=="out" then return end

    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        if data.refs.billboard.Adornee~=head then
            data.refs.billboard.Adornee=head
            if data.refs.shadowBB then data.refs.shadowBB.Adornee=head end
        end
        return
    end

    data.building=true
    if data.refs then
        if data.refs.billboard and data.refs.billboard.Parent then
            pcall(function() data.refs.billboard:Destroy() end)
        end
        if data.refs.shadowBB and data.refs.shadowBB.Parent then
            pcall(function() data.refs.shadowBB:Destroy() end)
        end
        data.refs=nil
    end

    if toggleBuild then
        data.fadeState="idle" data.fadeAlpha=0 data.currentTrans=masterAlpha
    else
        data.fadeState="in" data.fadeAlpha=1 data.currentTrans=1
    end
    local initTrans=data.currentTrans

    local ok,err=pcall(function()
        local refs=buildUI(player,head)
        refs.canvas.GroupTransparency=initTrans
        refs.shadowCanvas.GroupTransparency=initTrans
        data.refs=refs
    end)
    data.building=false
    if not ok then warn("[Nametags] attachToHead ["..player.Name.."]: "..tostring(err)) end
end

-- Tick per-player bez goto — wyodrębniony jako funkcja
local function tickPlayer(player,data,dt,lpRoot)
    -- Watchdog: brak billboardu lub zły adornee
    if enabled and not data.building and data.fadeState~="out" then
        local head=findHead(player)
        if head and head.Parent then
            if not data.refs then
                attachToHead(player,head,false)
                return
            elseif data.refs.billboard and data.refs.billboard.Parent then
                if data.refs.billboard.Adornee~=head then
                    data.refs.billboard.Adornee=head
                    if data.refs.shadowBB then data.refs.shadowBB.Adornee=head end
                end
            end
        end
    end

    if not data.refs then return end
    local refs=data.refs

    -- Anti-zombie
    if not refs.billboard or not refs.billboard.Parent then
        data.refs=nil data.fadeState="idle" data.fadeAlpha=1 data.currentTrans=1
        return
    end

    -- AdorneeParent=nil (stara glowa odlaczona po ;spongify itp.)
    if refs.billboard.Adornee and refs.billboard.Adornee.Parent==nil then
        local newHead=findHead(player)
        if newHead and newHead.Parent then
            refs.billboard.Adornee=newHead
            if refs.shadowBB then refs.shadowBB.Adornee=newHead end
        end
    end

    -- Per-player fade
    local fadeState=data.fadeState
    if fadeState=="in" then
        data.fadeAlpha=data.fadeAlpha+(0-data.fadeAlpha)*(1-exp(-CFG.PlayerFadeInSpeed*dt))
        if abs(data.fadeAlpha)<0.005 then
            data.fadeAlpha=0 data.fadeState="idle" fadeState="idle"
        end
    elseif fadeState=="out" then
        data.fadeAlpha=data.fadeAlpha+(1-data.fadeAlpha)*(1-exp(-CFG.PlayerFadeOutSpeed*dt))
        if data.fadeAlpha>0.995 then
            data.fadeAlpha=1 data.fadeState="idle" data.currentTrans=1
            if refs.billboard and refs.billboard.Parent then
                pcall(function() refs.billboard:Destroy() end)
            end
            if refs.shadowBB and refs.shadowBB.Parent then
                pcall(function() refs.shadowBB:Destroy() end)
            end
            data.refs=nil
            return
        end
    end

    -- Finalna przezroczystosc
    local finalTrans
    if fadeState=="idle" then
        finalTrans=masterAlpha data.currentTrans=finalTrans
    else
        local targetTrans=max(masterAlpha,data.fadeAlpha)
        local cur=data.currentTrans
        cur=cur+(targetTrans-cur)*(1-exp(-CFG.LerpSpeed*dt))
        data.currentTrans=cur finalTrans=cur
    end
    refs.canvas.GroupTransparency=finalTrans
    refs.shadowCanvas.GroupTransparency=finalTrans

    -- Dystans
    local char=player.Character
    local head=char and char:FindFirstChild("Head")
    if lpRoot and head then
        data.distTimer=(data.distTimer or 0)+dt
        if data.distTimer>=CFG.DistThrottle then
            data.distTimer=0
            local dist=(head.Position-lpRoot.Position).Magnitude
            local dc=distColor(dist)
            refs.distLabel.Text=format("%.0f studs",floor(dist))
            refs.distDot.TextColor3=dc
            refs.distLabel.TextColor3=dc
        end
    end
end

local function startGlobalHeartbeat()
    if globalHeartbeat then globalHeartbeat:Disconnect() globalHeartbeat=nil end
    globalHeartbeat=RunService.Heartbeat:Connect(function(dt)
        local lpChar=lp.Character
        local lpRoot=lpChar and lpChar:FindFirstChild("HumanoidRootPart")
        for player,data in pairs(tagData) do
            tickPlayer(player,data,dt,lpRoot)
        end
    end)
end

local function cleanupPlayer(player)
    local data=tagData[player]
    if not data then return end
    if data.charConns then
        for _,conn in ipairs(data.charConns) do conn:Disconnect() end
        data.charConns=nil
    end
    destroyTagUI(player,false)
    widthCache[player.UserId]=nil
    tagData[player]=nil
end

local function setupPlayer(player)
    if player==lp then return end
    if tagData[player] then return end

    tagData[player]={
        refs=nil, charConns=nil, fadeState="idle",
        fadeAlpha=1, building=false, distTimer=0, currentTrans=1,
    }
    local data=tagData[player]

    local charAdded=player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head=newChar:WaitForChild("Head",8)
            if not head then head=findHead(player) end
            if not head or not tagData[player] then return end
            if not enabled then return end

            local waited=0
            while head.Parent==nil and waited<5 do
                task.wait(0.1) waited=waited+0.1
            end
            if head.Parent==nil then return end

            local d=tagData[player]
            if d and d.refs then
                d.fadeState="out"
                task.wait(0.5)
            end
            if not tagData[player] then return end
            if not enabled then return end

            local currentHead=findHead(player)
            if currentHead and currentHead.Parent then
                attachToHead(player,currentHead,false)
            end
        end)
    end)

    -- Backup dla HD Admin ;char — lapie nowy Model bez CharacterAdded
    local childAdded=player.ChildAdded:Connect(function(child)
        if child:IsA("Model") and child.Name==player.Name then
            task.spawn(function()
                if not enabled then return end
                local d=tagData[player]
                if not d then return end
                task.wait(0.3)
                local head=child:FindFirstChild("Head")
                if not head then task.wait(1) head=child:FindFirstChild("Head") end
                if not head or not head.Parent then return end
                if not enabled or not tagData[player] then return end
                if d.refs then
                    if d.refs.billboard and d.refs.billboard.Parent then
                        pcall(function() d.refs.billboard:Destroy() end)
                    end
                    if d.refs.shadowBB and d.refs.shadowBB.Parent then
                        pcall(function() d.refs.shadowBB:Destroy() end)
                    end
                    d.refs=nil d.fadeState="idle" d.fadeAlpha=1 d.building=false
                end
                attachToHead(player,head,false)
            end)
        end
    end)

    local charRemoving=player.CharacterRemoving:Connect(function()
        local d=tagData[player]
        if d and d.refs then d.fadeState="out" end
    end)

    data.charConns={charAdded,charRemoving,childAdded}

    if enabled then
        local head=findHead(player)
        if head and head.Parent then attachToHead(player,head,false) end
    end
end

getgenv().Nametags = {
    enable = function()
        if enabled and not isTransitioning then return end
        isTransitioning=true enabled=true
        if masterAlphaConn then masterAlphaConn:Disconnect() masterAlphaConn=nil end
        masterAlpha=1
        startGlobalHeartbeat()
        for _,player in ipairs(Players:GetPlayers()) do
            if player==lp then continue end
            if not tagData[player] then setupPlayer(player) end
            local data=tagData[player]
            if not data then continue end
            if data.fadeState=="out" then continue end
            data.fadeState="idle" data.fadeAlpha=0 data.currentTrans=1
            local head=findHead(player)
            if head and head.Parent and not data.building then
                attachToHead(player,head,true)
            elseif data.refs then
                data.refs.canvas.GroupTransparency=1
                data.refs.shadowCanvas.GroupTransparency=1
                data.currentTrans=1
            end
        end
        animateMasterAlpha(0,CFG.ToggleLerpSpeed,function() isTransitioning=false end)
    end,

    disable = function()
        if not enabled and not isTransitioning then return end
        enabled=false isTransitioning=true
        for _,data in pairs(tagData) do
            if data.fadeState=="in" then data.fadeState="idle" data.fadeAlpha=0 end
        end
        animateMasterAlpha(1,CFG.ToggleLerpSpeed,function()
            isTransitioning=false
            if globalHeartbeat then globalHeartbeat:Disconnect() globalHeartbeat=nil end
            for player,_ in pairs(tagData) do destroyTagUI(player,false) end
            widthCache={}
        end)
    end,

    setColor = function(color)
        accentColor=color
        local ng=accentGradientColor(color)
        for _,data in pairs(tagData) do
            if data.refs then
                data.refs.accentBar.BackgroundColor3=color
                data.refs.accentGrad.Color=ng
                data.refs.ring.BackgroundColor3=color
            end
        end
    end,
}

getgenv().enableNametags     = getgenv().Nametags.enable
getgenv().disableNametags    = getgenv().Nametags.disable
getgenv().updateNametagColor = getgenv().Nametags.setColor

Players.PlayerAdded:Connect(setupPlayer)
Players.PlayerRemoving:Connect(function(player)
    local data=tagData[player]
    if not data then return end
    if data.refs then
        destroyTagUI(player,true)
        task.delay(1.2,function() cleanupPlayer(player) end)
    else
        cleanupPlayer(player)
    end
end)

for _,player in ipairs(Players:GetPlayers()) do
    setupPlayer(player)
end
