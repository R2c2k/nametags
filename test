    shadowBB.Name             = "DarkNametag_Shadow_" .. player.Name
    shadowBB.Adornee          = head
    shadowBB.Size             = UDim2.fromOffset(totalWidth + 4, CFG.Height + 4)
    shadowBB.StudsOffset      = CFG.StudsOffset + Vector3.new(0, -0.04, -0.01)
    shadowBB.AlwaysOnTop      = CFG.AlwaysOnTop
    shadowBB.ResetOnSpawn     = false
    shadowBB.ClipsDescendants = false
    shadowBB.ZIndexBehavior   = Enum.ZIndexBehavior.Sibling
    shadowBB.Parent           = tagContainer

    -- CanvasGroup dla shadow żeby fade razem z głównym
    local shadowCanvas = Instance.new("CanvasGroup", shadowBB)
    shadowCanvas.Size                   = UDim2.fromScale(1, 1)
    shadowCanvas.BackgroundTransparency = 1
    shadowCanvas.GroupTransparency      = 1

    local shadowFrame = Instance.new("Frame", shadowCanvas)
    shadowFrame.Size                   = UDim2.fromScale(1, 1)
    shadowFrame.Position               = UDim2.fromOffset(0, 0)
    shadowFrame.BackgroundColor3       = CFG.ShadowColor
    shadowFrame.BackgroundTransparency = CFG.ShadowTrans
    shadowFrame.BorderSizePixel        = 0
    Instance.new("UICorner", shadowFrame).CornerRadius = UDim.new(0, cr + 2)

    -- Gradient na shadow (dół ciemniejszy) — głębia
    local shadowGrad = Instance.new("UIGradient", shadowFrame)
    shadowGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.new(0, 0, 0)),
        ColorSequenceKeypoint.new(1, Color3.new(0, 0, 0)),
