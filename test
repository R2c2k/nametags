-- Stała kwadratowa dla overlap — liczymy raz, używamy w O(n²) pętli
-- Unika pierwiastka kwadratowego przy każdym porównaniu pary tagów
local OVERLAP_PX_SQ = CFG.OverlapPx * CFG.OverlapPx

-- ─────────────────────────────────────────────
--   Stan globalny
-- ─────────────────────────────────────────────

local enabled     = false
local accentColor = CFG.Accent

-- Cache avatarów: userId -> URL obrazka
-- Kluczowany po UserId — przeżywa respawn i ;char
