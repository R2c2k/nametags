-- ─────────────────────────────────────────────
--   Animacja masterAlpha
-- ─────────────────────────────────────────────

local function animateMasterAlpha(targetAlpha, speed, onDone)
    if masterAlphaConn then
        masterAlphaConn:Disconnect()
        masterAlphaConn = nil
    end

    if abs(masterAlpha - targetAlpha) < 0.002 then
        masterAlpha = targetAlpha
        if onDone then onDone() end
        return
    end

    masterAlphaConn = RunService.Heartbeat:Connect(function(dt)
        local diff = targetAlpha - masterAlpha
        if abs(diff) < 0.002 then
            masterAlpha = targetAlpha
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
            if onDone then onDone() end
            return
        end
        masterAlpha = masterAlpha + diff * (1 - exp(-speed * dt))
    end)
end

