local function destroyRefs(data)
    if not data.refs then return end
    if data.refs.billboard and data.refs.billboard.Parent then
        pcall(function() data.refs.billboard:Destroy() end)
    end
    if data.refs.shadowBB and data.refs.shadowBB.Parent then
        pcall(function() data.refs.shadowBB:Destroy() end)
    end
    data.refs = nil
end

local function destroyTagUI(player, withFade)
    local data = tagData[player]
    if not data then return end

    if withFade and data.refs then
        data.fadeState = "out"
    else
        destroyRefs(data)
        data.fadeState      = "idle"
        data.fadeAlpha      = 1
        data.currentTrans   = 1
        data.building       = false
        data.rebuildPending = false
        data._gen           = (data._gen or 0) + 1
    end
end

-- ─────────────────────────────────────────────
--   Podpięcie taga do głowy
--
--  [FIX v19.4] Używa generation counter zamiast
--  boolean building. Każde nowe żądanie budowy
--  inkrementuje _gen — poprzedni build widzi że
--  jego generacja jest przestarzała i się nie zapisuje.
--  Dzięki temu szybkie ;char A → ;char B nie blokuje się
--  nawzajem przez building=true.
-- ─────────────────────────────────────────────

local function attachToHead(player, head, toggleBuild)
    local data = tagData[player]
    if not data or not enabled then return end
    if not head or not isAlive(head) then return end

    -- Anuluj ongoing fade-out (HD Admin natychmiastowy respawn)
    if data.fadeState == "out" then
        destroyRefs(data)
        data.fadeState      = "idle"
        data.fadeAlpha      = 1
        data.currentTrans   = 1
        data.rebuildPending = false
    end

    -- Billboard już istnieje — sprawdź czy Adornee żyje
    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        local adornee   = data.refs.billboard.Adornee
        local adorneeOk = isAlive(adornee)

        if adorneeOk then
            if adornee ~= head then
                data.refs.billboard.Adornee = head
                if data.refs.shadowBB then
                    data.refs.shadowBB.Adornee = head
                end
            end
            data.rebuildPending = false
            return
        end

        -- Adornee martwy — zniszcz
        destroyRefs(data)
    end

    -- [FIX] Inkrementuj generację — anuluje wszystkie poprzednie
    -- task.spawny które czekają na buildUI tej postaci
    data._gen = (data._gen or 0) + 1
    local myGen = data._gen

    data.building       = true
    data.rebuildPending = false

    if toggleBuild then
        data.fadeState    = "idle"
        data.fadeAlpha    = 0
        data.currentTrans = masterAlpha
    else
        data.fadeState    = "in"
        data.fadeAlpha    = 1
        data.currentTrans = 1
    end

    local initTrans = data.currentTrans

    -- Uruchom build w osobnym task.spawn żeby nie blokować callera
    -- (CharacterAdded callback, Heartbeat zombie detection)
    task.spawn(function()
        -- Sprawdź czy ta generacja wciąż aktualna
        local d = tagData[player]
        if not d or d._gen ~= myGen then
            -- Przestarzała generacja — nowy build już jest w drodze
            return
        end
        if not enabled then
            d.building = false
            return
        end
        if not isAlive(head) then
            d.building = false
            -- Head zniknął zanim zdążyliśmy zbudować —
            -- CharacterAdded dla nowej postaci zadba o rebuild
            return
        end

        local ok, err = pcall(function()
            local refs = buildUI(player, head)

            -- Ostatnia weryfikacja generacji przed zapisem
            -- (buildUI może trwać kilka ms, przez ten czas mogła
            -- przyjść kolejna zmiana postaci)
            local d2 = tagData[player]
            if not d2 or d2._gen ~= myGen then
                -- Przestarzałe — zniszcz właśnie zbudowane UI
                if refs.billboard and refs.billboard.Parent then
                    pcall(function() refs.billboard:Destroy() end)
                end
                if refs.shadowBB and refs.shadowBB.Parent then
                    pcall(function() refs.shadowBB:Destroy() end)
                end
                return
            end

            refs.canvas.GroupTransparency       = initTrans
            refs.shadowCanvas.GroupTransparency = initTrans
            d2.refs     = refs
            d2.building = false
        end)

        if not ok then
            local d2 = tagData[player]
            if d2 then d2.building = false end
            warn("[Nametags] attachToHead [" .. player.Name .. "]: " .. tostring(err))
        end
    end)
end

-- ─────────────────────────────────────────────
--   Główna pętla Heartbeat
-- ─────────────────────────────────────────────

local function startGlobalHeartbeat()
    if globalHeartbeat then
        globalHeartbeat:Disconnect()
        globalHeartbeat = nil
    end

    local cachedLpRoot = nil

    local function updateLpRoot(char)
        cachedLpRoot = char and char:FindFirstChild("HumanoidRootPart") or nil
    end

    updateLpRoot(lp.Character)

    lp.CharacterAdded:Connect(function(newChar)
        task.delay(0.1, function()
            cachedLpRoot = newChar:FindFirstChild("HumanoidRootPart")
        end)
    end)
    lp.CharacterRemoving:Connect(function()
        cachedLpRoot = nil
    end)

    globalHeartbeat = RunService.Heartbeat:Connect(function(dt)
        local lpRoot = cachedLpRoot

        for player, data in tagData do
            if not data.refs then
                -- [FIX] DEAD STATE recovery:
                -- refs=nil + building=false + gracz ma Head + nametagi włączone
                -- = tag zniknął na stałe i nic go nie odbudowuje
                -- Heartbeat sam zainicjuje rebuild zamiast czekać na event
                if not data.building and not data.rebuildPending
                    and data.fadeState == "idle" and enabled
                then
                    local char = player.Character
                    local head = char and char:FindFirstChild("Head")
                    if head then
                        data.rebuildPending = true
                        task.spawn(function()
                            local d = tagData[player]
                            if not d or not d.rebuildPending then return end
                            if not enabled then
                                if d then d.rebuildPending = false end
                                return
                            end
                            d.rebuildPending = false
                            attachToHead(player, head, false)
                        end)
                    end
                end
                continue
            end

            local refs = data.refs

            if not refs.billboard or not refs.billboard.Parent then
                data.refs         = nil
                data.fadeState    = "idle"
                data.fadeAlpha    = 1
                data.currentTrans = 1
                data.building     = false
                data.rebuildPending = false
                continue
            end

            -- Zombie adornee detection
            do
                local adornee   = refs.billboard.Adornee
                local adorneeOk = isAlive(adornee)

                if not adorneeOk and not data.rebuildPending and not data.building then
                    local char        = player.Character
                    local currentHead = char and char:FindFirstChild("Head")

                    destroyRefs(data)
                    data.building = false

                    if currentHead and enabled then
                        data.rebuildPending = true
                        data.fadeState      = "in"
                        data.fadeAlpha      = 1
                        data.currentTrans   = 1

                        local capturedGen = (data._gen or 0)
                        task.spawn(function()
                            local d = tagData[player]
                            if not d or not d.rebuildPending then return end
                            if not enabled then
                                if d then d.rebuildPending = false end
                                return
                            end
                            -- Jeśli generacja się zmieniła to znaczy że
                            -- attachToHead już był wywołany z zewnątrz
                            if d._gen ~= capturedGen then
                                d.rebuildPending = false
                                return
                            end
                            d.rebuildPending = false
                            attachToHead(player, currentHead, false)
                        end)
                    else
                        data.rebuildPending = false
                        data.fadeState      = "idle"
                        data.fadeAlpha      = 1
                        data.currentTrans   = 1
                    end
                    continue
                end

                if not adorneeOk then continue end
            end

            local fadeState = data.fadeState

            if fadeState == "in" then
                data.fadeAlpha = data.fadeAlpha + (0 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeInSpeed * dt))
                if abs(data.fadeAlpha) < 0.005 then
                    data.fadeAlpha = 0
                    data.fadeState = "idle"
                end
            elseif fadeState == "out" then
                data.fadeAlpha = data.fadeAlpha + (1 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeOutSpeed * dt))
                if data.fadeAlpha > 0.995 then
                    data.fadeAlpha    = 1
                    data.fadeState    = "idle"
                    data.currentTrans = 1
                    destroyRefs(data)
                    continue
                end
            end

            local finalTrans
            if fadeState == "idle" then
                finalTrans        = masterAlpha
                data.currentTrans = finalTrans
            else
                local targetTrans = max(masterAlpha, data.fadeAlpha)
                local cur         = data.currentTrans
                cur               = cur + (targetTrans - cur) * (1 - exp(-CFG.LerpSpeed * dt))
                data.currentTrans = cur
                finalTrans        = cur
            end

            if data.refs then
                data.refs.canvas.GroupTransparency       = finalTrans
                data.refs.shadowCanvas.GroupTransparency = finalTrans
            end

            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if lpRoot and head and data.refs then
                data.distTimer = (data.distTimer or 0) + dt
                if data.distTimer >= CFG.DistThrottle then
                    data.distTimer = 0
                    local dist = (head.Position - lpRoot.Position).Magnitude
                    local dc   = distColor(dist)
                    data.refs.distLabel.Text       = format("%.0f studs", floor(dist))
                    data.refs.distDot.TextColor3   = dc
                    data.refs.distLabel.TextColor3 = dc
                end
            end
        end
    end)
end

-- ─────────────────────────────────────────────
--   Cleanup gracza
-- ─────────────────────────────────────────────

local function cleanupPlayer(player)
    local data = tagData[player]
    if not data then return end

    if data.charConns then
        for _, conn in data.charConns do
            pcall(function() conn:Disconnect() end)
        end
        data.charConns = nil
    end

    destroyTagUI(player, false)
    widthCache[player.UserId] = nil
    tagData[player] = nil
end

-- ─────────────────────────────────────────────
--   Setup gracza
-- ─────────────────────────────────────────────

local function setupPlayer(player)
    if player == lp then return end
    if tagData[player] then return end

    tagData[player] = {
        refs            = nil,
        charConns       = nil,
        fadeState       = "idle",
        fadeAlpha       = 1,
        building        = false,
        rebuildPending  = false,
        distTimer       = 0,
        currentTrans    = 1,
        _gen            = 0,
    }

    local data = tagData[player]

    local charAdded = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            -- Inkrementuj generację natychmiast przy nowym CharacterAdded
            -- żeby poprzedni build (jeśli trwał) wiedział że jest przestarzały
            local d = tagData[player]
            if not d then return end

            -- Zresetuj flagi — nowa postać w drodze
            d.building       = false
            d.rebuildPending = false
            d.fadeState      = "idle"
            d.fadeAlpha      = 1
            d.currentTrans   = 1
            -- Nie inkrementujemy _gen tutaj — zrobi to attachToHead

            local head = newChar:WaitForChild("Head", 5)
            if not head then return end

            -- Sprawdź czy ta postać wciąż aktualna
            -- Używamy generacji zamiast player.Character porównania
            -- bo player.Character może być jeszcze nieaktualne
            local d2 = tagData[player]
            if not d2 then return end
            if not enabled then return end

            -- Dodatkowy guard: czy Head jest z aktualnej postaci?
            if not isAlive(head) then return end
            if head.Parent ~= newChar then return end
            if not isAlive(newChar) then return end

            attachToHead(player, head, false)
        end)
    end)

    local charRemoving = player.CharacterRemoving:Connect(function()
        local d = tagData[player]
        if not d then return end
        -- Zacznij fade-out istniejącego taga
        if d.refs then
            d.fadeState = "out"
        end
        -- Reset pending — nowa postać jeszcze nie istnieje
        d.rebuildPending = false
        -- Nie resetujemy building — attachToHead w task.spawn sam się
        -- zatrzyma przez generation check
    end)

    data.charConns = { charAdded, charRemoving }

    if enabled then
        local char = player.Character
        local head = char and char:FindFirstChild("Head")
        if head then
            attachToHead(player, head, false)
        end
    end
end

-- ─────────────────────────────────────────────
--   Publiczne API
-- ─────────────────────────────────────────────

getgenv().Nametags = {

    enable = function()
        if enabled and not isTransitioning then return end

        isTransitioning = true
        enabled = true

        if masterAlphaConn then
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
        end
        masterAlpha = 1

        startGlobalHeartbeat()

        for _, player in Players:GetPlayers() do
            if player == lp then continue end

            if not tagData[player] then
                setupPlayer(player)
            end

            local data = tagData[player]
            if not data then continue end
            if data.fadeState == "out" then continue end

            -- [FIX] Pełny reset przy enable — zapobiega
            -- "zamrożonym" flagom z poprzedniej sesji
            data.building       = false
            data.rebuildPending = false
            data.fadeState      = "idle"
            data.fadeAlpha      = 0
            data.currentTrans   = 1

            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if head then
                attachToHead(player, head, true)
            elseif data.refs then
                data.refs.canvas.GroupTransparency       = 1
                data.refs.shadowCanvas.GroupTransparency = 1
                data.currentTrans = 1
            end
        end

        animateMasterAlpha(0, CFG.ToggleLerpSpeed, function()
            isTransitioning = false
        end)
    end,

    disable = function()
        if not enabled and not isTransitioning then return end

        enabled = false
        isTransitioning = true

        for _, data in tagData do
            if data.fadeState == "in" then
                data.fadeState = "idle"
                data.fadeAlpha = 0
            end
            data.rebuildPending = false
        end

        animateMasterAlpha(1, CFG.ToggleLerpSpeed, function()
            isTransitioning = false

            if globalHeartbeat then
                globalHeartbeat:Disconnect()
                globalHeartbeat = nil
            end

            for player, _ in tagData do
                destroyTagUI(player, false)
            end

            widthCache = {}
        end)
    end,

    setColor = function(color)
        accentColor = color
        local newGradient = accentGradientColor(color)
        for _, data in tagData do
            if data.refs then
                data.refs.accentBar.BackgroundColor3 = color
                data.refs.accentGrad.Color           = newGradient
                data.refs.ring.BackgroundColor3      = color
            end
        end
    end,
}

getgenv().enableNametags     = getgenv().Nametags.enable
getgenv().disableNametags    = getgenv().Nametags.disable
getgenv().updateNametagColor = getgenv().Nametags.setColor

-- ─────────────────────────────────────────────
--   Inicjalizacja
-- ─────────────────────────────────────────────

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(player)
    local data = tagData[player]
    if not data then return end

    if data.refs then
        destroyTagUI(player, true)
        task.delay(1.2, function()
            cleanupPlayer(player)
        end)
    else
        cleanupPlayer(player)
    end
end)

for _, player in Players:GetPlayers() do
    setupPlayer(player)
end
