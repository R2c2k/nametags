-- ─────────────────────────────────────────────
--   Per-player Heartbeat
-- ─────────────────────────────────────────────

local function startLoop(player, r)
    local ct        = 1
    local distTimer = 0
    local conn
    conn = S.Run.Heartbeat:Connect(function(dt)
        if not r.bb or not r.bb.Parent then conn:Disconnect() return end
        local lc   = LP.Character
        local lrp  = lc and lc:FindFirstChild("HumanoidRootPart")
        local ch   = player.Character
        local head = ch and ch:FindFirstChild("Head")
        if not lrp or not head then
            ct = lerp(ct, 1, math.min(dt * C.LerpSpeed, 1))
            r.cv.GroupTransparency = ct
            return
        end
        distTimer = distTimer + dt
        if distTimer >= 0.16 then
            distTimer = 0
            local dist = (head.Position - lrp.Position).Magnitude
            r.dl.Text = string.format("%.0f studs", dist)
            local dc = distColor(dist)
            r.dot.TextColor3 = dc
            r.dl.TextColor3  = dc
        end
        local dist2 = (head.Position - lrp.Position).Magnitude
        local td    = tags[player]
        local pen   = td and td.overlapTrans or 0
        local goal  = math.max(fadeTrans(dist2), pen)
        ct = lerp(ct, goal, math.min(dt * C.LerpSpeed, 1))
        r.cv.GroupTransparency = ct
    end)
    return conn
end

-- ─────────────────────────────────────────────
--   Global overlap loop
-- ─────────────────────────────────────────────

local function startGlobal()
    if globalLoop then globalLoop:Disconnect() end
    globalLoop = S.Run.Heartbeat:Connect(function()
        local lc  = LP.Character
        local lrp = lc and lc:FindFirstChild("HumanoidRootPart")
        local ent = {}
        for pl, d in tags do
            if not d.refs then continue end
            local ch   = pl.Character
            local head = ch and ch:FindFirstChild("Head")
            if not head then continue end
            local dist = lrp and (head.Position - lrp.Position).Magnitude or math.huge
            table.insert(ent, { pl = pl, dist = dist, sc = w2s(head.Position + C.StudsOffset) })
        end
        table.sort(ent, function(a, b) return a.dist < b.dist end)
        for _, e in ent do
            local d = tags[e.pl]
            if d then d.overlapTrans = 0 end
        end
        for i = 1, #ent do
            if not ent[i].sc then continue end
            for j = i + 1, #ent do
                if not ent[j].sc then continue end
                local px = (ent[i].sc - ent[j].sc).Magnitude
                if px < C.OverlapPx then
                    local dj = tags[ent[j].pl]
                    if dj then
                        dj.overlapTrans = math.max(
                            dj.overlapTrans or 0,
                            (1 - px / C.OverlapPx) * C.OverlapBonus
                        )
                    end
                end
            end
        end
    end)
end

-- ─────────────────────────────────────────────
--   Tag lifecycle
-- ─────────────────────────────────────────────

local function destroyTagUI(player)
    local d = tags[player]
    if not d then return end
    if d.heartbeat then d.heartbeat:Disconnect() d.heartbeat = nil end
    if d.refs and d.refs.killAvatar then d.refs.killAvatar() end
    if d.refs and d.refs.bb and d.refs.bb.Parent then d.refs.bb:Destroy() end
    d.refs         = nil
    d.overlapTrans = 0
end

local function destroyTag(player)
    local d = tags[player]
    if not d then return end
    destroyTagUI(player)
    if d.charConn then d.charConn:Disconnect() d.charConn = nil end
    d.watchToken = nil
    tags[player] = nil
end

-- ─────────────────────────────────────────────
--   Attach tag do Head przez Adornee
-- ─────────────────────────────────────────────

local function attachToHead(player, head)
    local d = tags[player]
    if not d or not enabled then return end
    if not head or not head.Parent then return end

    -- Jeśli już mamy tag z tym samym Adornee — nie przebudowuj
    if d.refs and d.refs.bb and d.refs.bb.Adornee == head then return end

    destroyTagUI(player)

    local ok, err = pcall(function()
        local refs = buildUI(player, head)
        local hb   = startLoop(player, refs)
        d.refs      = refs
        d.heartbeat = hb
    end)

    if not ok then
        warn("attachToHead fail [" .. player.Name .. "]: " .. tostring(err))
    end
end

-- ─────────────────────────────────────────────
--   Watcher — polling co 0.5s
--   Jedyne co sprawdzamy to czy Adornee BB
--   nadal wskazuje na aktualny Head gracza.
--   Jeśli nie — aktualizujemy Adornee lub
--   przebudowujemy tag.
-- ─────────────────────────────────────────────

local function startWatcher(player)
    local d = tags[player]
    if not d then return end

    local token = {}
    d.watchToken = token

    task.spawn(function()
        while true do
            task.wait(0.5)

            local dd = tags[player]
            if not dd or dd.watchToken ~= token then return end
            if not enabled then return end

            local ch   = player.Character
            local head = ch and ch:FindFirstChild("Head")

            if not ch or not head then
                if dd.refs then destroyTagUI(player) end
                continue
            end

            -- Przypadek 1: mamy refs i Adornee wskazuje na aktualny Head — OK
            if dd.refs and dd.refs.bb and dd.refs.bb.Parent
                and dd.refs.bb.Adornee == head then
                continue
            end

            -- Przypadek 2: brak refs LUB Adornee się zdezaktualizował
            -- (nowy Head po ;char — Head.Locked nie blokuje Adornee!)
            if dd.refs and dd.refs.bb and dd.refs.bb.Parent
                and dd.refs.bb.Adornee ~= head then
                -- Wystarczy zaktualizować Adornee — nie trzeba przebudowywać
                dd.refs.bb.Adornee = head
                continue
            end

            -- Przypadek 3: brak refs — zbuduj od nowa
            attachToHead(player, head)
        end
    end)
end

-- ─────────────────────────────────────────────
--   Setup gracza
-- ─────────────────────────────────────────────

local function setupPlayer(player)
    if player == LP then return end
    if tags[player] then return end

    tags[player] = {
        refs         = nil,
        heartbeat    = nil,
        charConn     = nil,
        watchToken   = nil,
        overlapTrans = 0,
    }
    local d = tags[player]

    -- CharacterAdded: szybka ścieżka dla ;re
    d.charConn = player.CharacterAdded:Connect(function(newChar)
        task.spawn(function()
            local head
            local deadline = tick() + 5
            while tick() < deadline do
                if not tags[player] then return end
                head = newChar:FindFirstChild("Head")
                if head then break end
                task.wait(0.05)
            end
            if not head or not tags[player] then return end
            attachToHead(player, head)
        end)
    end)

    -- Watcher: obsługuje ;char (bez CharacterAdded) i wszystko inne
    startWatcher(player)
end

-- ─────────────────────────────────────────────
--   Globalne API
-- ─────────────────────────────────────────────

getgenv().enableNametags = function()
    enabled = true
    for _, p in S.Players:GetPlayers() do
        if p == LP then continue end
        if not tags[p] then
            setupPlayer(p)
        else
            local d = tags[p]
            if not d.watchToken then startWatcher(p) end
        end
    end
    startGlobal()
end

getgenv().disableNametags = function()
    enabled = false
    for pl, d in tags do
        destroyTagUI(pl)
        d.watchToken = nil
    end
    if globalLoop then globalLoop:Disconnect() globalLoop = nil end
end

getgenv().updateNametagColor = function(color)
    accentColor = color
    for _, d in tags do
        if d.refs then
            d.refs.ab.BackgroundColor3 = color
            d.refs.abGrad.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                ColorSequenceKeypoint.new(1, accentDark(color)),
            })
            d.refs.ring.BackgroundColor3 = color
        end
    end
end

