local tagData = {}

-- Globalne pętle
local globalLoop   = nil
local globalWatcher = nil

-- ─────────────────────────────────────────────
--   Kontener GUI w CoreGui
-- ─────────────────────────────────────────────

local tagContainer = CoreGui:FindFirstChild("NametagContainer")
