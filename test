    distLabel.Text                   = ""
    distLabel.Size                   = UDim2.fromOffset(textWidth - 12, 11)
    distLabel.Position               = UDim2.fromOffset(textOffset + 11, 34)
    distLabel.Font                   = CFG.FontMeta
