-- ─────────────────────────────────────────────

Players.PlayerAdded:Connect(setupPlayer)

Players.PlayerRemoving:Connect(function(player)
    local data = tagData[player]
    if not data then return end

    if data.refs then
        destroyTagUI(player, true)
        -- Czas na fade-out (~0.6s przy PlayerFadeOutSpeed=7) + margines
        task.delay(1.2, function()
            cleanupPlayer(player)
        end)
    else
        cleanupPlayer(player)
    end
end)

-- Inicjalizacja dla graczy już obecnych w grze
for _, player in Players:GetPlayers() do
    setupPlayer(player)
end
