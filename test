-- ─────────────────────────────────────────────
--   Pomocnicze
-- ─────────────────────────────────────────────

local function lerpColor(c1, c2, t)
    return Color3.new(
        c1.R + (c2.R - c1.R) * t,
        c1.G + (c2.G - c1.G) * t,
        c1.B + (c2.B - c1.B) * t
    )
end

local function distColor(d)
    local close = CFG.DistClose
    local far   = CFG.DistFar
    local mid   = (close + far) * 0.5
    if d <= close then
        return CFG.ColorClose
    elseif d <= mid then
        return lerpColor(CFG.ColorClose, CFG.ColorMid, (d - close) / (mid - close))
    elseif d <= far then
        return lerpColor(CFG.ColorMid, CFG.ColorFar, (d - mid) / (far - mid))
    else
        return CFG.ColorFar
    end
end

local function accentGradientColor(color)
    return ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.new(
            math.min(color.R * 1.35, 1),
            math.min(color.G * 1.35, 1),
            math.min(color.B * 1.35, 1)
        )),
        ColorSequenceKeypoint.new(1, Color3.new(
            color.R * 0.55,
            color.G * 0.55,
            color.B * 0.55
        )),
    })
end

-- Sprawdzenie żywości obiektu bez pcall
local function isAlive(instance)
    if not instance then return false end
    return instance.Parent ~= nil
end

