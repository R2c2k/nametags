-- ─────────────────────────────────────────────
--   Animacja masterAlpha — bezpieczna, anty-spam
-- ─────────────────────────────────────────────

local function animateMasterAlpha(targetAlpha, speed, onDone)
    if masterAlphaConn then
        masterAlphaConn:Disconnect()
        masterAlphaConn = nil
    end

    if abs(masterAlpha - targetAlpha) < 0.002 then
        masterAlpha = targetAlpha
        if onDone then onDone() end
        return
    end

    masterAlphaConn = RunService.Heartbeat:Connect(function(dt)
        local diff = targetAlpha - masterAlpha
        if abs(diff) < 0.002 then
            masterAlpha = targetAlpha
            masterAlphaConn:Disconnect()
            masterAlphaConn = nil
            if onDone then onDone() end
            return
        end
        masterAlpha = masterAlpha + diff * (1 - exp(-speed * dt))
    end)
end

-- ─────────────────────────────────────────────
--   Niszczenie UI taga
--   withFade: true  = płynny fade-out przed destroy (przez globalny HB)
--            false = natychmiastowe usunięcie
-- ─────────────────────────────────────────────

local function destroyTagUI(player, withFade)
    local data = tagData[player]
    if not data then return end

    if withFade and data.refs then
        -- FIX: nie resetujemy fadeAlpha do 0 — zaczynamy fade-out od aktualnej wartości
        -- żeby nie było flasha. Globalny HB ogarnie resztę.
        data.fadeState = "out"
        -- fadeAlpha zostawiamy na aktualnym poziomie (nie dotykamy)
    else
        -- Natychmiastowe zniszczenie
        if data.refs then
            if data.refs.billboard and data.refs.billboard.Parent then
                pcall(function() data.refs.billboard:Destroy() end)
            end
            if data.refs.shadowBB and data.refs.shadowBB.Parent then
                pcall(function() data.refs.shadowBB:Destroy() end)
            end
            data.refs = nil
        end
        data.fadeState   = "idle"
        data.fadeAlpha   = 1
        data.currentTrans = 1
        data.building    = false
    end
end

-- ─────────────────────────────────────────────
--   Podpięcie taga pod głowę
--   toggleBuild: true  = budujemy podczas toggle enable
--                       → startujemy z masterAlpha, brak własnego fade-in
--               false  = normalny spawn postaci
--                       → startujemy z 1, własny fade-in
-- ─────────────────────────────────────────────

local function attachToHead(player, head, toggleBuild)
    local data = tagData[player]
    if not data or not enabled then return end
    if not head or not head.Parent then return end
    if data.building then return end
    if data.fadeState == "out" then return end

    -- Jeśli tag już istnieje na tej głowie — tylko aktualizuj adornee
    if data.refs and data.refs.billboard and data.refs.billboard.Parent then
        if data.refs.billboard.Adornee ~= head then
            data.refs.billboard.Adornee = head
            if data.refs.shadowBB then
                data.refs.shadowBB.Adornee = head
            end
        end
        return
    end

    data.building = true

    -- Zniszcz stary UI bez fade (jeśli coś zostało)
    if data.refs then
        if data.refs.billboard and data.refs.billboard.Parent then
            pcall(function() data.refs.billboard:Destroy() end)
        end
        if data.refs.shadowBB and data.refs.shadowBB.Parent then
            pcall(function() data.refs.shadowBB:Destroy() end)
        end
        data.refs = nil
    end

    if toggleBuild then
        -- Toggle: masterAlpha jest jedynym sterownikiem — fadeState idle, playerFade = 0
        data.fadeState    = "idle"
        data.fadeAlpha    = 0
        data.currentTrans = masterAlpha
    else
        -- Spawn: własny fade-in od 1 do 0
        data.fadeState    = "in"
        data.fadeAlpha    = 1
        data.currentTrans = 1
    end

    local initTrans = data.currentTrans

    local ok, err = pcall(function()
        local refs = buildUI(player, head)

        -- Ustaw GroupTransparency natychmiast — brak skoku przy pierwszej klatce HB
        refs.canvas.GroupTransparency       = initTrans
        refs.shadowCanvas.GroupTransparency = initTrans

        data.refs = refs
    end)

    data.building = false

    if not ok then
        warn("[Nametags] attachToHead [" .. player.Name .. "]: " .. tostring(err))
    end
end

-- ─────────────────────────────────────────────
--   Globalna pętla Heartbeat
--   JEDNA dla wszystkich graczy
--
--   FIX: Per-player lerp TYLKO przy własnym fade (spawn/despawn).
--   Podczas toggle (fadeState == "idle") — bezpośrednio masterAlpha
--   bez dodatkowego lerpa. Wszystkie tagi idle poruszają się SYNCHRONICZNIE.
-- ─────────────────────────────────────────────

local function startGlobalHeartbeat()
    if globalHeartbeat then
        globalHeartbeat:Disconnect()
        globalHeartbeat = nil
    end

    globalHeartbeat = RunService.Heartbeat:Connect(function(dt)
        local lpChar = lp.Character
        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")

        for player, data in tagData do
            if not data.refs then continue end

            local refs = data.refs
            if not refs.billboard or not refs.billboard.Parent then
                -- Billboard zniknął z zewnątrz — wyczyść refs (anti-zombie)
                data.refs         = nil
                data.fadeState    = "idle"
                data.fadeAlpha    = 1
                data.currentTrans = 1
                continue
            end

            -- ── Per-player fade (spawn/despawn) ──────────
            local fadeState = data.fadeState

            if fadeState == "in" then
                -- Lerp fadeAlpha: 1 → 0
                data.fadeAlpha = data.fadeAlpha + (0 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeInSpeed * dt))
                if abs(data.fadeAlpha) < 0.005 then
                    data.fadeAlpha = 0
                    data.fadeState = "idle"
                end

            elseif fadeState == "out" then
                -- Lerp fadeAlpha: aktualna → 1
                data.fadeAlpha = data.fadeAlpha + (1 - data.fadeAlpha) * (1 - exp(-CFG.PlayerFadeOutSpeed * dt))
                if data.fadeAlpha > 0.995 then
                    -- Fade-out zakończony — zniszcz UI
                    data.fadeAlpha    = 1
                    data.fadeState    = "idle"
                    data.currentTrans = 1
                    if refs.billboard and refs.billboard.Parent then
                        pcall(function() refs.billboard:Destroy() end)
                    end
                    if refs.shadowBB and refs.shadowBB.Parent then
                        pcall(function() refs.shadowBB:Destroy() end)
                    end
                    data.refs = nil
                    continue
                end
            end

            -- ── Finalna przezroczystość ───────────────────
            --
            -- FIX: Kluczowa zmiana względem v18.
            -- fadeState == "idle"  → bezpośrednio masterAlpha (synchroniczne z innymi)
            -- fadeState == "in/out" → lerp per-player od currentTrans → max(masterAlpha, fadeAlpha)
            --
            -- Efekt: podczas toggle wszystkie tagi poruszają się razem (jeden lerp = masterAlpha).
            -- Podczas spawn/despawn konkretnego gracza — własny, niezależny lerp.

            local finalTrans

            if fadeState == "idle" then
                -- Bez per-tag lerpa — masterAlpha jest tu jedynym źródłem prawdy
                finalTrans        = masterAlpha
                data.currentTrans = finalTrans
            else
                -- Per-player fade: max(masterAlpha, fadeAlpha) z własnym lerpem
                local targetTrans = max(masterAlpha, data.fadeAlpha)
                local cur         = data.currentTrans
                cur               = cur + (targetTrans - cur) * (1 - exp(-CFG.LerpSpeed * dt))
                data.currentTrans = cur
                finalTrans        = cur
            end

            refs.canvas.GroupTransparency       = finalTrans
            refs.shadowCanvas.GroupTransparency = finalTrans

            -- ── Dystans ───────────────────────────────────
            local char = player.Character
            local head = char and char:FindFirstChild("Head")

            if lpRoot and head then
                data.distTimer = (data.distTimer or 0) + dt
                if data.distTimer >= CFG.DistThrottle then
                    data.distTimer = 0
                    local dist = (head.Position - lpRoot.Position).Magnitude
                    local dc   = distColor(dist)
                    refs.distLabel.Text       = format("%.0f studs", floor(dist))
                    refs.distDot.TextColor3   = dc
                    refs.distLabel.TextColor3 = dc
                end
            end
        end
    end)
end

