-- ─────────────────────────────────────────────
--   Utility
-- ─────────────────────────────────────────────

local exp = math.exp
local clamp = math.clamp
local format = string.format

local function lerpColor(c1, c2, t)
    return Color3.new(
        c1.R + (c2.R - c1.R) * t,
        c1.G + (c2.G - c1.G) * t,
        c1.B + (c2.B - c1.B) * t
    )
end

local function distColor(d)
    local mid = (CFG.DistClose + CFG.DistFar) * 0.5
    if d <= CFG.DistClose then
        return CFG.ColorClose
    elseif d <= mid then
        return lerpColor(CFG.ColorClose, CFG.ColorMid, (d - CFG.DistClose) / (mid - CFG.DistClose))
    elseif d <= CFG.DistFar then
        return lerpColor(CFG.ColorMid, CFG.ColorFar, (d - mid) / (CFG.DistFar - mid))
    else
        return CFG.ColorFar
    end
end

local function fadeTrans(d)
    if d < CFG.FadeNearMin then return 1 end
    if d < CFG.FadeNearMax then return 1 - (d - CFG.FadeNearMin) / (CFG.FadeNearMax - CFG.FadeNearMin) end
    if d < CFG.FadeFarMin  then return 0 end
    if d < CFG.FadeFarMax  then return (d - CFG.FadeFarMin) / (CFG.FadeFarMax - CFG.FadeFarMin) end
    return 1
end

-- [FIX #6] Klucz po UserId — odporny na zmianę DisplayName
local function calcWidth(player)
    local userId = player.UserId
    if widthCache[userId] then return widthCache[userId] end

    local dispName    = player.DisplayName
    local userName    = player.Name
    local avatarOffset = CFG.AvatarSize + 18
    local bigBounds   = Vector2.new(9999, 16)
    local subBounds   = Vector2.new(9999, 13)

    local w = math.max(
        TextService:GetTextSize(dispName,        11, CFG.FontMain, bigBounds).X,
        TextService:GetTextSize("@" .. userName,  9, CFG.FontSub,  subBounds).X,
        TextService:GetTextSize("999 studs",       8, CFG.FontMeta, subBounds).X
    )

    local result = clamp(avatarOffset + w + CFG.WidthPadR, CFG.WidthMin, CFG.WidthMax)
    widthCache[userId] = result
    return result
end

-- Projekcja world → screen (nil jeśli za kamerą)
local function worldToScreen(pos)
    local sp, onScreen = Camera:WorldToScreenPoint(pos)
    if not onScreen or sp.Z <= 0 then return nil end
    return Vector2.new(sp.X, sp.Y)
end

local function accentDark(color)
    return Color3.new(color.R * 0.6, color.G * 0.6, color.B * 0.6)
end

