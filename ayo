local enabled     = false
local accentColor = C.Accent
local tags        = {}
local globalLoop  = nil

local function lerp(a, b, t)
    return a + (b - a) * t
end

local function lerpColor(c1, c2, t)
    return Color3.new(lerp(c1.R, c2.R, t), lerp(c1.G, c2.G, t), lerp(c1.B, c2.B, t))
end

local function distColor(d)
    local mid = (C.DistClose + C.DistFar) / 2
    if d <= C.DistClose then return C.ColorClose
    elseif d <= mid      then return lerpColor(C.ColorClose, C.ColorMid, (d - C.DistClose) / (mid - C.DistClose))
    elseif d <= C.DistFar then return lerpColor(C.ColorMid, C.ColorFar, (d - mid) / (C.DistFar - mid))
    else return C.ColorFar end
end

local function fadeTrans(d)
    if d < C.FadeNearMin then return 1 end
    if d < C.FadeNearMax then return 1 - (d - C.FadeNearMin) / (C.FadeNearMax - C.FadeNearMin) end
    if d < C.FadeFarMin  then return 0 end
    if d < C.FadeFarMax  then return (d - C.FadeFarMin) / (C.FadeFarMax - C.FadeFarMin) end
    return 1
end

local function calcWidth(dispName, userName)
    local tx  = C.AvatarSize + 18
    local big = Vector2.new(9999, 16)
    local sub = Vector2.new(9999, 13)
    local w = math.max(
        S.Text:GetTextSize(dispName,       11, C.FontMain, big).X,
        S.Text:GetTextSize("@"..userName,   9, C.FontSub,  sub).X,
        S.Text:GetTextSize("999 studs",     8, C.FontMeta, sub).X
    )
    return math.clamp(tx + w + C.WidthPadR, C.WidthMin, C.WidthMax)
end

local function w2s(pos)
    local sp, on = S.Camera:WorldToScreenPoint(pos)
    if not on or sp.Z <= 0 then return nil end
    return Vector2.new(sp.X, sp.Y)
end

local function mkLabel(parent, props)
    local l = Instance.new("TextLabel", parent)
    for k, v in props do l[k] = v end
    return l
end

local function mkFrame(parent, props)
    local f = Instance.new("Frame", parent)
    for k, v in props do f[k] = v end
    return f
end

local function accentDark(color)
    return Color3.fromRGB(
        math.floor(color.R * 255 * 0.6),
        math.floor(color.G * 255 * 0.6),
        math.floor(color.B * 255 * 0.6)
    )
end

local function buildUI(player, head)
    local dw = calcWidth(player.DisplayName, player.Name)
    local tx = C.AvatarSize + 18
    local tw = dw - tx - C.WidthPadR
    local f  = {}

    f.bb = Instance.new("BillboardGui")
