    f.bb.Adornee          = head
    f.bb.Size             = UDim2.fromOffset(dw, C.H)
    f.bb.StudsOffset      = C.StudsOffset
    f.bb.AlwaysOnTop      = C.AlwaysOnTop
    f.bb.ResetOnSpawn     = false
    f.bb.ClipsDescendants = false
    f.bb.Parent           = head

    f.cv = Instance.new("CanvasGroup", f.bb)
    f.cv.Size                   = UDim2.fromScale(1, 1)
    f.cv.BackgroundTransparency = 1
    f.cv.GroupTransparency      = 1

    f.sh = mkFrame(f.cv, {
        Size                   = UDim2.fromScale(1, 1),
        Position               = UDim2.fromOffset(2, 3),
        BackgroundColor3       = C.ShadowColor,
        BackgroundTransparency = C.ShadowTrans,
        BorderSizePixel        = 0,
        ZIndex                 = 1,
    })
    Instance.new("UICorner", f.sh).CornerRadius = UDim.new(0, 8)

    f.gl = mkFrame(f.cv, {
        Size                   = UDim2.fromScale(1, 1),
        BackgroundColor3       = C.GlassColor,
        BackgroundTransparency = C.GlassTrans,
        BorderSizePixel        = 0,
        ZIndex                 = 2,
    })
    Instance.new("UICorner", f.gl).CornerRadius = UDim.new(0, 8)

    f.bs = Instance.new("UIStroke", f.gl)
    f.bs.Color           = C.BorderColor
    f.bs.Transparency    = C.BorderTrans
    f.bs.Thickness       = 1
    f.bs.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    f.ab = mkFrame(f.gl, {
        Name             = "AccentBar",
        Size             = UDim2.new(0, 3, 1, -12),
        Position         = UDim2.fromOffset(5, 6),
        BackgroundColor3 = accentColor,
        BorderSizePixel  = 0,
        ZIndex           = 3,
