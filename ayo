local C = {
    H            = 46,
    AvatarSize   = 28,
    WidthMin     = 100,
    WidthMax     = 500,
    WidthPadR    = 10,
    StudsOffset  = Vector3.new(0, 2.4, 0),
    AlwaysOnTop  = true,
    FadeNearMin  = 2,
    FadeNearMax  = 6,
    FadeFarMin   = 55,
    FadeFarMax   = 70,
    OverlapPx    = 180,
    OverlapBonus = 0.65,
    LerpSpeed    = 12,
    GlassColor   = Color3.fromRGB(25, 25, 25),
    GlassTrans   = 0.12,
    BorderColor  = Color3.fromRGB(60, 60, 60),
    BorderTrans  = 0.40,
    ShadowColor  = Color3.fromRGB(0, 0, 0),
    ShadowTrans  = 0.60,
    Accent       = Color3.fromRGB(0, 160, 255),
    TextMain     = Color3.fromRGB(240, 240, 240),
    TextSub      = Color3.fromRGB(178, 178, 178),
    TextMeta     = Color3.fromRGB(140, 140, 140),
    SepColor     = Color3.fromRGB(50, 50, 65),
    DistClose    = 20,
    DistFar      = 60,
    ColorClose   = Color3.fromRGB(80, 220, 120),
    ColorMid     = Color3.fromRGB(255, 200, 60),
    ColorFar     = Color3.fromRGB(255, 80, 80),
    FontMain     = Enum.Font.GothamBold,
    FontSub      = Enum.Font.Gotham,
    FontMeta     = Enum.Font.Gotham,
