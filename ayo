    Instance.new("UICorner", f.ab).CornerRadius = UDim.new(0, 3)

    f.abGrad = Instance.new("UIGradient", f.ab)
    f.abGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
        ColorSequenceKeypoint.new(1, accentDark(accentColor)),
    })
    f.abGrad.Rotation = 90

    f.ring = mkFrame(f.gl, {
        Size             = UDim2.fromOffset(C.AvatarSize + 3, C.AvatarSize + 3),
        Position         = UDim2.new(0, 12, 0.5, 0),
        AnchorPoint      = Vector2.new(0, 0.5),
        BackgroundColor3 = accentColor,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    })
    Instance.new("UICorner", f.ring).CornerRadius = UDim.new(1, 0)

    f.av = Instance.new("ImageLabel", f.gl)
    f.av.Name                   = "Avatar"
    f.av.Size                   = UDim2.fromOffset(C.AvatarSize, C.AvatarSize)
    f.av.Position               = UDim2.new(0, 13, 0.5, 0)
    f.av.AnchorPoint            = Vector2.new(0, 0.5)
    f.av.BackgroundColor3       = Color3.fromRGB(30, 30, 38)
    f.av.BackgroundTransparency = 0
    f.av.Image                  = ""
    f.av.ZIndex                 = 4
    Instance.new("UICorner", f.av).CornerRadius = UDim.new(1, 0)

    local avatarToken = {}
    task.spawn(function()
        local myToken = avatarToken
        local ok, img = pcall(
            S.Players.GetUserThumbnailAsync, S.Players,
            player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48
        )
        if ok and avatarToken == myToken and f.av.Parent then
            f.av.Image                  = img
            f.av.BackgroundTransparency = 1
        end
    end)

    mkLabel(f.gl, {
        Text                   = player.DisplayName,
        Size                   = UDim2.fromOffset(tw, 16),
        Position               = UDim2.fromOffset(tx, 6),
        Font                   = C.FontMain,
        TextColor3             = C.TextMain,
        TextSize               = 11,
        TextScaled             = false,
        TextXAlignment         = Enum.TextXAlignment.Left,
        BackgroundTransparency = 1,
        ZIndex                 = 4,
    })

    mkLabel(f.gl, {
        Text                   = "@" .. player.Name,
        Size                   = UDim2.fromOffset(tw, 12),
        Position               = UDim2.fromOffset(tx, 21),
        Font                   = C.FontSub,
        TextColor3             = C.TextSub,
        TextSize               = 9,
